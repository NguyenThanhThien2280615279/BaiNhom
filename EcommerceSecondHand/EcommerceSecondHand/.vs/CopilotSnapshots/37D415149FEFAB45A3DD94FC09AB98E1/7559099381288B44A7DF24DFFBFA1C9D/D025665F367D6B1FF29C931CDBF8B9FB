@model VendorDashboardViewModel
@{
    ViewData["Title"] = "Dashboard người bán";
}

<div class="container-fluid mt-4">
    <h1>Dashboard người bán</h1>
    
    <div class="row mt-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Tổng sản phẩm</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalProducts</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-box-seam fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Tổng doanh thu</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalRevenue.ToString("C")</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-currency-dollar fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Đơn hàng đã bán</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalSales</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-receipt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Đánh giá trung bình</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @if (Model.AverageRating > 0)
                                {
                                    for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Floor((double)Model.AverageRating))
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else if (i - 0.5 <= (double)Model.AverageRating)
                                        {
                                            <i class="bi bi-star-half text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                    <span class="ms-2">@Model.AverageRating.ToString("0.0")</span>
                                }
                                else
                                {
                                    <span>Chưa có đánh giá</span>
                                }
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-star fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Doanh thu theo tháng</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Thông tin tài khoản</h6>
                    <a href="/Account/Edit" class="btn btn-sm btn-primary">Chỉnh sửa</a>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column align-items-center text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.User?.ProfilePicture))
                        {
                            <img src="@Model.User.ProfilePicture" alt="@Model.User.FirstName" class="rounded-circle img-thumbnail" width="150" height="150" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                                <i class="bi bi-person-fill" style="font-size: 5rem;"></i>
                            </div>
                        }
                        <h4 class="mt-3">@Model.User?.FirstName @Model.User?.LastName</h4>
                        <p class="text-muted">Người bán</p>
                    </div>
                    
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-envelope me-2"></i> Email</span>
                            <span>@Model.User?.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-telephone me-2"></i> Số điện thoại</span>
                            <span>@(Model.User?.PhoneNumber ?? "Chưa cập nhật")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-geo-alt me-2"></i> Địa chỉ</span>
                            <span>@(Model.User?.Address ?? "Chưa cập nhật")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-wallet2 me-2"></i> Số dư ví</span>
                            <span>@Model.User?.WalletBalance.ToString("C")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-calendar-check me-2"></i> Ngày tham gia</span>
                            <span>@Model.User?.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Sản phẩm mới nhất</h6>
                    <div>
                        <a href="/Vendor/AddProduct" class="btn btn-sm btn-success me-2">
                            <i class="bi bi-plus-lg"></i> Thêm sản phẩm
                        </a>
                        <a href="/Vendor/Products" class="btn btn-sm btn-primary">
                            Xem tất cả
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Danh mục</th>
                                    <th>Giá</th>
                                    <th>Tình trạng</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày đăng</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentProducts.Any())
                                {
                                    foreach (var product in Model.RecentProducts)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                                    {
                                                        <img src="@product.ImageUrl" class="me-2" alt="@product.Name" width="40" height="40" style="object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                                            <i class="bi bi-image text-muted"></i>
                                                        </div>
                                                    }
                                                    <a href="/Products/Details/@product.Id">@product.Name</a>
                                                </div>
                                            </td>
                                            <td>@product.Category?.Name</td>
                                            <td>@product.Price.ToString("C")</td>
                                            <td>
                                                <span class="badge @GetProductConditionBadgeClass(product.Condition)">
                                                    @GetProductConditionText(product.Condition)
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(product.IsAvailable ? "bg-success" : "bg-danger")">
                                                    @(product.IsAvailable ? "Còn hàng" : "Hết hàng")
                                                </span>
                                            </td>
                                            <td>@product.CreatedAt.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="/Vendor/EditProduct/@product.Id" class="btn btn-sm btn-primary">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form method="post" asp-controller="Vendor" asp-action="DeleteProduct" asp-route-id="@product.Id" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center">Bạn chưa có sản phẩm nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Đơn hàng gần đây</h6>
                    <a href="/Vendor/Orders" class="btn btn-sm btn-primary">Xem tất cả</a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Mã đơn hàng</th>
                                    <th>Khách hàng</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày đặt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentOrders.Any())
                                {
                                    foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td>
                                                <a href="/Orders/Details/@order.Id">#@order.OrderNumber</a>
                                            </td>
                                            <td>@(order.User?.FirstName ?? "") @(order.User?.LastName ?? "")</td>
                                            <td>@order.TotalAmount.ToString("C")</td>
                                            <td>
                                                <span class="badge @GetOrderStatusBadgeClass(order.Status)">
                                                    @GetOrderStatusText(order.Status)
                                                </span>
                                            </td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">Bạn chưa có đơn hàng nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Đánh giá gần đây</h6>
                    <a href="/Vendor/Reviews" class="btn btn-sm btn-primary">Xem tất cả</a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Khách hàng</th>
                                    <th>Đánh giá</th>
                                    <th>Nhận xét</th>
                                    <th>Ngày đánh giá</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentReviews.Any())
                                {
                                    foreach (var review in Model.RecentReviews)
                                    {
                                        <tr>
                                            <td>
                                                <a href="/Products/Details/@review.ProductId">@review.Product?.Name</a>
                                            </td>
                                            <td>@(review.User?.FirstName ?? "") @(review.User?.LastName ?? "")</td>
                                            <td>
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= review.Rating)
                                                    {
                                                        <i class="bi bi-star-fill text-warning"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star text-warning"></i>
                                                    }
                                                }
                                            </td>
                                            <td>@review.Comment</td>
                                            <td>@review.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">Bạn chưa có đánh giá nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Biểu đồ doanh thu
        var ctx = document.getElementById('revenueChart').getContext('2d');
        var revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'],
                datasets: [{
                    label: 'Doanh thu',
                    data: [
                        @Model.Statistics?.MonthlyRevenue[0],
                        @Model.Statistics?.MonthlyRevenue[1],
                        @Model.Statistics?.MonthlyRevenue[2],
                        @Model.Statistics?.MonthlyRevenue[3],
                        @Model.Statistics?.MonthlyRevenue[4],
                        @Model.Statistics?.MonthlyRevenue[5],
                        @Model.Statistics?.MonthlyRevenue[6],
                        @Model.Statistics?.MonthlyRevenue[7],
                        @Model.Statistics?.MonthlyRevenue[8],
                        @Model.Statistics?.MonthlyRevenue[9],
                        @Model.Statistics?.MonthlyRevenue[10],
                        @Model.Statistics?.MonthlyRevenue[11]
                    ],
                    backgroundColor: 'rgba(78, 115, 223, 0.05)',
                    borderColor: 'rgba(78, 115, 223, 1)',
                    pointRadius: 3,
                    pointBackgroundColor: 'rgba(78, 115, 223, 1)',
                    pointBorderColor: 'rgba(78, 115, 223, 1)',
                    pointHoverRadius: 5,
                    pointHoverBackgroundColor: 'rgba(78, 115, 223, 1)',
                    pointHoverBorderColor: 'rgba(78, 115, 223, 1)',
                    pointHitRadius: 10,
                    pointBorderWidth: 2,
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}

@functions {
    public string GetProductConditionBadgeClass(ProductCondition condition)
    {
        return condition switch
        {
            ProductCondition.New => "bg-success",
            ProductCondition.LikeNew => "bg-info",
            ProductCondition.Good => "bg-primary",
            ProductCondition.Fair => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
    
    public string GetProductConditionText(ProductCondition condition)
    {
        return condition switch
        {
            ProductCondition.New => "Mới",
            ProductCondition.LikeNew => "Như mới",
            ProductCondition.Good => "Tốt",
            ProductCondition.Fair => "Khá",
            _ => condition.ToString()
        };
    }
    
    public string GetOrderStatusBadgeClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "bg-warning text-dark",
            OrderStatus.Processing => "bg-info text-dark",
            OrderStatus.Shipped => "bg-primary",
            OrderStatus.Delivered => "bg-success",
            OrderStatus.Cancelled => "bg-danger",
            OrderStatus.Refunded => "bg-secondary",
            _ => "bg-secondary"
        };
    }
    
    public string GetOrderStatusText(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "Chờ xử lý",
            OrderStatus.Processing => "Đang xử lý",
            OrderStatus.Shipped => "Đang vận chuyển",
            OrderStatus.Delivered => "Đã giao hàng",
            OrderStatus.Cancelled => "Đã hủy",
            OrderStatus.Refunded => "Đã hoàn tiền",
            _ => status.ToString()
        };
    }
}