                <div class="card-body">
                    <form method="post" asp-controller="Wallet" asp-action="Withdraw">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">VND</span>
                                <input asp-for="Amount" class="form-control" type="number" min="50000" max="100000000" step="10000">
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <div class="form-text">S? ti?n t?i thi?u là 50,000 VND. T?i ?a là 100,000,000 VND.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="WithdrawalMethod" class="form-label"></label>
                            <select asp-for="WithdrawalMethod" class="form-select" id="withdrawalMethod">
                                <option value="">-- Ch?n ph??ng th?c rút ti?n --</option>
                                <option value="BankTransfer">Chuy?n kho?n ngân hàng</option>
                                <option value="Momo">Ví MoMo</option>
                                <option value="ZaloPay">ZaloPay</option>
                                <option value="VNPay">VNPay</option>
                            </select>
                            <span asp-validation-for="WithdrawalMethod" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="AccountInfo" class="form-label"></label>
                            <div id="bankTransferFields" class="withdrawal-fields" style="display: none;">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="bankName" placeholder="Tên ngân hàng">
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="accountNumber" placeholder="S? tài kho?n">
                                    </div>
                                    <div class="col-12">
                                        <input type="text" class="form-control mb-2" id="accountName" placeholder="Tên ch? tài kho?n">
                                    </div>
                                    <div class="col-12">
                                        <input type="text" class="form-control mb-2" id="branch" placeholder="Chi nhánh (n?u có)">
                                    </div>
                                </div>
                            </div>
                            
                            <div id="ewalletFields" class="withdrawal-fields" style="display: none;">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="phoneNumber" placeholder="S? ?i?n tho?i">
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="fullName" placeholder="H? và tên">
                                    </div>
                                </div>
                            </div>
                            
                            <textarea asp-for="AccountInfo" class="form-control" rows="3" placeholder="Thông tin tài kho?n" readonly style="display: none;"></textarea>
                            <span asp-validation-for="AccountInfo" class="text-danger"></span>
                            <div class="form-text">Vui lòng nh?p ??y ?? thông tin tài kho?n ?? nh?n ti?n.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nh?p ghi chú n?u có"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <div class="alert alert-warning">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h5 class="alert-heading">L?u ý quan tr?ng</h5>
                                        <p class="mb-0">Sau khi nh?n "Rút ti?n", yêu c?u c?a b?n s? ???c g?i ??n admin ?? x? lý. Quá trình này có th? m?t t? 1-3 ngày làm vi?c. Vui lòng ki?m tra k? thông tin tài kho?n ?? tránh sai sót.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/Wallet" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay l?i
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-wallet2"></i> Rút ti?n
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">?i?u kho?n và ?i?u ki?n</h5>
                </div>
                <div class="card-body">
                    <ol>
                        <li>S? ti?n t?i thi?u cho m?i l?n rút là 50,000 VND.</li>
                        <li>S? ti?n t?i ?a cho m?i l?n rút là 100,000,000 VND.</li>
                        <li>Phí rút ti?n: Mi?n phí (trong th?i gian khuy?n mãi).</li>
                        <li>Th?i gian x? lý: 1-3 ngày làm vi?c.</li>
                        <li>Yêu c?u rút ti?n ch? ???c ch?p nh?n khi tài kho?n c?a b?n ?ã ???c xác minh.</li>
                        <li>Ti?n s? ch? ???c chuy?n ??n tài kho?n có tên chính ch? trùng v?i tên tài kho?n c?a b?n trên h? th?ng.</li>
                        <li>N?u thông tin tài kho?n không chính xác, yêu c?u rút ti?n có th? b? t? ch?i và b?n s? c?n t?o yêu c?u m?i.</li>
                        <li>??i v?i các yêu c?u rút ti?n trên 10,000,000 VND, chúng tôi có th? yêu c?u xác minh b? sung.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // X? lý hi?n th? các tr??ng thông tin d?a trên ph??ng th?c rút ti?n
            $('#withdrawalMethod').change(function() {
                const method = $(this).val();
                $('.withdrawal-fields').hide();
                $('#AccountInfo').hide().val('');
                
                if (method === 'BankTransfer') {
                    $('#bankTransferFields').show();
                    resetFields('#ewalletFields input');
                } else if (['Momo', 'ZaloPay', 'VNPay'].includes(method)) {
                    $('#ewalletFields').show();
                    resetFields('#bankTransferFields input');
                }
            });
            
            // C?p nh?t thông tin tài kho?n khi ng??i dùng nh?p
            $('body').on('input', '.withdrawal-fields input', function() {
                updateAccountInfo();
            });
            
            function resetFields(selector) {
                $(selector).val('');
            }
            
            function updateAccountInfo() {
                const method = $('#withdrawalMethod').val();
                let info = '';
                
                if (method === 'BankTransfer') {
                    const bankName = $('#bankName').val().trim();
                    const accountNumber = $('#accountNumber').val().trim();
                    const accountName = $('#accountName').val().trim();
                    const branch = $('#branch').val().trim();
                    
                    if (bankName || accountNumber || accountName) {
                        info = `Ngân hàng: ${bankName || 'N/A'}\n`;
                        info += `S? tài kho?n: ${accountNumber || 'N/A'}\n`;
                        info += `Ch? tài kho?n: ${accountName || 'N/A'}`;
                        
                        if (branch) {
                            info += `\nChi nhánh: ${branch}`;
                        }
                    }
                } else if (['Momo', 'ZaloPay', 'VNPay'].includes(method)) {
                    const phoneNumber = $('#phoneNumber').val().trim();
                    const fullName = $('#fullName').val().trim();
                    
                    if (phoneNumber || fullName) {
                        info = `${method}\n`;
                        info += `S? ?i?n tho?i: ${phoneNumber || 'N/A'}\n`;
                        info += `H? và tên: ${fullName || 'N/A'}`;
                    }
                }
                
                if (info) {
                    $('#AccountInfo').val(info).show();
                } else {
                    $('#AccountInfo').hide().val('');
                }
            }
        });
    </script>
}