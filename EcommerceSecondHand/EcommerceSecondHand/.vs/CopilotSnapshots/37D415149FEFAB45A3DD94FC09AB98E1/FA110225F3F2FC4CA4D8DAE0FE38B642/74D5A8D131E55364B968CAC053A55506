<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcommerceSecondHand</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcommerceSecondHand.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bag-heart-fill text-primary me-2"></i>
                    EcommerceSecondHand
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang ch?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Products" asp-action="Index">S?n ph?m</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Index">Qu?n tr?</a>
                            </li>
                        }
                        @if (User.IsInRole("Vendor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Vendor" asp-action="Index">Kênh ng??i bán</a>
                            </li>
                        }
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Customer" asp-action="Index">Khách hàng</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex">
                        <form class="d-flex me-2" asp-controller="Search" asp-action="Index" method="get">
                            <input class="form-control me-2" type="search" name="query" placeholder="Tìm ki?m s?n ph?m..." aria-label="Search">
                            <button class="btn btn-outline-primary" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>
                        
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex align-items-center">
                                <div class="dropdown me-2">
                                    <a href="#" class="btn btn-outline-secondary position-relative" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-bell"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notification-badge">
                                            0
                                        </span>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="notificationDropdown" style="min-width: 300px; max-width: 400px;">
                                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                            <h6 class="mb-0">Thông báo</h6>
                                            <a href="#" class="text-decoration-none" id="mark-all-read">?ánh d?u ?ã ??c</a>
                                        </div>
                                        <div id="notification-list" style="max-height: 300px; overflow-y: auto;">
                                            <div class="text-center py-3">
                                                <div class="spinner-border text-primary" role="status">
                                                    <span class="visually-hidden">?ang t?i...</span>
                                                </div>
                                            </div>
                                        </div>
                                        <a asp-controller="WebNotifications" asp-action="Index" class="dropdown-item text-center border-top py-2">
                                            Xem t?t c? thông báo
                                        </a>
                                    </div>
                                </div>
                                
                                <a asp-controller="WebCart" asp-action="Index" class="btn btn-outline-secondary position-relative me-2">
                                    <i class="bi bi-cart"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" id="cart-badge">
                                        0
                                    </span>
                                </a>
                                
                                <div class="dropdown">
                                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <img src="https://github.com/mdo.png" alt="User" width="32" height="32" class="rounded-circle me-2">
                                        <span>@User.Identity.Name</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">H? s?</a></li>
                                        <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">??n hàng c?a tôi</a></li>
                                        <li><a class="dropdown-item" asp-controller="Messages" asp-action="Index">Tin nh?n</a></li>
                                        <li><a class="dropdown-item" asp-controller="Wallet" asp-action="Index">Ví ?i?n t?</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">??ng xu?t</a></li>
                                    </ul>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary me-2" asp-area="Identity" asp-page="/Account/Login">??ng nh?p</a>
                            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">??ng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5>EcommerceSecondHand</h5>
                    <p>N?n t?ng mua bán ?? c? ch?t l??ng hàng ??u Vi?t Nam.</p>
                    <div class="d-flex gap-2">
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-facebook fs-5"></i>
                        </a>
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-instagram fs-5"></i>
                        </a>
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-twitter-x fs-5"></i>
                        </a>
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-linkedin fs-5"></i>
                        </a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h6>Thông tin</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="About" class="text-decoration-none">Gi?i thi?u</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Chính sách b?o m?t</a></li>
                        <li><a asp-controller="Home" asp-action="Terms" class="text-decoration-none">?i?u kho?n s? d?ng</a></li>
                        <li><a asp-controller="Home" asp-action="Contact" class="text-decoration-none">Liên h?</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4">
                    <h6>D?ch v?</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="HowToSell" class="text-decoration-none">Cách bán hàng</a></li>
                        <li><a asp-controller="Home" asp-action="HowToBuy" class="text-decoration-none">Cách mua hàng</a></li>
                        <li><a asp-controller="Home" asp-action="Shipping" class="text-decoration-none">V?n chuy?n</a></li>
                        <li><a asp-controller="Home" asp-action="Payments" class="text-decoration-none">Thanh toán</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6>Liên h? v?i chúng tôi</h6>
                    <address>
                        <p><i class="bi bi-geo-alt me-2"></i> 123 ???ng Cách M?ng Tháng 8, Qu?n 3, TP. H? Chí Minh</p>
                        <p><i class="bi bi-telephone me-2"></i> (84) 123-456-789</p>
                        <p><i class="bi bi-envelope me-2"></i> <a href="mailto:info@ecommercesecondhand.com">info@ecommercesecondhand.com</a></p>
                    </address>
                </div>
            </div>
            <hr>
            <div class="d-flex justify-content-between">
                <p>&copy; @DateTime.Now.Year - EcommerceSecondHand. All rights reserved.</p>
                <p>
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Chính sách b?o m?t</a> |
                    <a asp-controller="Home" asp-action="Terms" class="text-decoration-none">?i?u kho?n s? d?ng</a>
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @if (User.Identity.IsAuthenticated)
    {
        <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
        <script>
            // L?y s? l??ng thông báo ch?a ??c
            function loadUnreadNotificationsCount() {
                fetch('/api/Notifications/GetUnreadCount')
                    .then(response => response.json())
                    .then(count => {
                        const badge = document.getElementById('notification-badge');
                        if (count > 0) {
                            badge.textContent = count > 99 ? '99+' : count;
                            badge.style.display = 'block';
                        } else {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(error => console.error('Error:', error));
            }
            
            // L?y danh sách thông báo g?n ?ây
            function loadRecentNotifications() {
                fetch('/api/Notifications/GetRecent')
                    .then(response => response.json())
                    .then(notifications => {
                        const notificationList = document.getElementById('notification-list');
                        
                        if (notifications.length === 0) {
                            notificationList.innerHTML = `
                                <div class="text-center py-3">
                                    <p class="text-muted mb-0">Không có thông báo m?i</p>
                                </div>
                            `;
                            return;
                        }
                        
                        let html = '';
                        notifications.forEach(notification => {
                            const date = new Date(notification.createdAt);
                            const formattedDate = `${date.getDate()}/${date.getMonth() + 1}/${date.getFullYear()} ${date.getHours()}:${date.getMinutes().toString().padStart(2, '0')}`;
                            
                            const iconClass = getNotificationIconClass(notification.type);
                            
                            html += `
                                <a href="${notification.actionUrl || '#'}" class="dropdown-item ${!notification.isRead ? 'bg-light' : ''}" data-id="${notification.id}">
                                    <div class="d-flex">
                                        <div class="flex-shrink-0 me-2">
                                            <i class="${iconClass} fs-5"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <h6 class="mb-0">${notification.title}</h6>
                                                <small class="text-muted">${formattedDate}</small>
                                            </div>
                                            <p class="mb-0 text-muted small">${notification.message}</p>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        
                        notificationList.innerHTML = html;
                        
                        // X? lý s? ki?n khi click vào thông báo
                        const notificationItems = notificationList.querySelectorAll('.dropdown-item');
                        notificationItems.forEach(item => {
                            item.addEventListener('click', function(e) {
                                const id = this.getAttribute('data-id');
                                if (!this.classList.contains('bg-light')) {
                                    return;
                                }
                                
                                fetch(`/api/Notifications/MarkAsRead/${id}`, {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json'
                                    }
                                })
                                .then(response => {
                                    if (response.ok) {
                                        this.classList.remove('bg-light');
                                        loadUnreadNotificationsCount();
                                    }
                                })
                                .catch(error => console.error('Error:', error));
                            });
                        });
                    })
                    .catch(error => console.error('Error:', error));
            }
            
            // ?ánh d?u t?t c? thông báo ?ã ??c
            document.getElementById('mark-all-read').addEventListener('click', function(e) {
                e.preventDefault();
                
                fetch('/api/Notifications/MarkAllAsRead', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => {
                    if (response.ok) {
                        loadUnreadNotificationsCount();
                        loadRecentNotifications();
                    }
                })
                .catch(error => console.error('Error:', error));
            });
            
            // L?y s? l??ng s?n ph?m trong gi? hàng
            function loadCartItemsCount() {
                fetch('/api/Cart/ItemsCount')
                    .then(response => response.json())
                    .then(count => {
                        const badge = document.getElementById('cart-badge');
                        if (count > 0) {
                            badge.textContent = count > 99 ? '99+' : count;
                            badge.style.display = 'block';
                        } else {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(error => console.error('Error:', error));
            }
            
            // L?y icon class d?a vào lo?i thông báo
            function getNotificationIconClass(type) {
                switch (type) {
                    case 0: // Information
                        return 'bi bi-info-circle text-info';
                    case 1: // Order
                        return 'bi bi-box text-primary';
                    case 2: // Payment
                        return 'bi bi-credit-card text-success';
                    case 3: // Message
                        return 'bi bi-chat-dots text-warning';
                    case 4: // Promotion
                        return 'bi bi-tag text-danger';
                    case 5: // Review
                        return 'bi bi-star text-warning';
                    default:
                        return 'bi bi-bell text-secondary';
                }
            }
            
            // K?t n?i SignalR
            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/notificationHub')
                .build();
                
            connection.on('ReceiveNotification', function() {
                loadUnreadNotificationsCount();
                loadRecentNotifications();
            });
            
            connection.start()
                .then(() => {
                    console.log('?ã k?t n?i ??n notification hub');
                })
                .catch(err => console.error('L?i k?t n?i ??n notification hub:', err));
            
            // T?i d? li?u khi trang ???c t?i
            document.addEventListener('DOMContentLoaded', function() {
                loadUnreadNotificationsCount();
                loadRecentNotifications();
                loadCartItemsCount();
                
                // T?i l?i d? li?u khi click vào dropdown thông báo
                document.getElementById('notificationDropdown').addEventListener('click', function() {
                    loadRecentNotifications();
                });
            });
        </script>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>