@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container">
    <!-- Banner chính -->
    <div id="mainCarousel" class="carousel slide shadow-sm mb-4" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner rounded">
            <div class="carousel-item active">
                <img src="https://via.placeholder.com/1200x400?text=Sale+Up+To+50%" class="d-block w-100" alt="Ưu đãi đặc biệt">
                <div class="carousel-caption d-none d-md-block">
                    <h2>Ưu đãi đặc biệt lên đến 50%</h2>
                    <p>Khám phá các sản phẩm giảm giá đặc biệt hôm nay</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-light">Mua ngay</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://via.placeholder.com/1200x400?text=Electronic+Deals" class="d-block w-100" alt="Sản phẩm điện tử">
                <div class="carousel-caption d-none d-md-block">
                    <h2>Thế giới điện tử cũ</h2>
                    <p>Các sản phẩm điện tử chất lượng với giá ưu đãi</p>
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="1" class="btn btn-light">Xem ngay</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://via.placeholder.com/1200x400?text=Fashion+Collection" class="d-block w-100" alt="Thời trang">
                <div class="carousel-caption d-none d-md-block">
                    <h2>Thời trang secondhand</h2>
                    <p>Phong cách bền vững cho môi trường</p>
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="2" class="btn btn-light">Khám phá</a>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Trước</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Tiếp</span>
        </button>
    </div>
    
    <!-- Danh mục sản phẩm -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-4">Danh mục sản phẩm</h2>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="1" class="text-decoration-none">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <i class="bi bi-laptop fs-1 text-primary mb-3"></i>
                        <h5 class="card-title">Điện tử</h5>
                        <p class="card-text">Laptop, điện thoại, máy tính bảng và phụ kiện</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="2" class="text-decoration-none">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <i class="bi bi-handbag fs-1 text-danger mb-3"></i>
                        <h5 class="card-title">Thời trang</h5>
                        <p class="card-text">Quần áo, giày dép, túi xách và phụ kiện</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="3" class="text-decoration-none">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <i class="bi bi-house-door fs-1 text-success mb-3"></i>
                        <h5 class="card-title">Nội thất</h5>
                        <p class="card-text">Bàn ghế, tủ, giường và đồ trang trí</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="4" class="text-decoration-none">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <i class="bi bi-controller fs-1 text-warning mb-3"></i>
                        <h5 class="card-title">Giải trí</h5>
                        <p class="card-text">Sách, đĩa, trò chơi và nhạc cụ</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- Sản phẩm nổi bật -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Sản phẩm nổi bật</h2>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">Xem tất cả</a>
            </div>
        </div>
        
        <!-- Placeholder cho các sản phẩm nổi bật -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <img src="https://via.placeholder.com/300x200?text=Featured+Product" class="card-img-top" alt="Sản phẩm nổi bật">
                <div class="card-body">
                    <h5 class="card-title">Laptop ThinkPad X1 Carbon</h5>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-primary fw-bold">$800.00</span>
                        <span class="badge bg-success">Như mới</span>
                    </div>
                    <div class="mt-2">
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-half text-warning"></i>
                        <small class="text-muted ms-1">(24)</small>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-grid">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="1" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <img src="https://via.placeholder.com/300x200?text=Featured+Product" class="card-img-top" alt="Sản phẩm nổi bật">
                <div class="card-body">
                    <h5 class="card-title">iPhone 12 Pro Max</h5>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-primary fw-bold">$650.00</span>
                        <span class="badge bg-primary">Tốt</span>
                    </div>
                    <div class="mt-2">
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star text-warning"></i>
                        <small class="text-muted ms-1">(18)</small>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-grid">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="2" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <img src="https://via.placeholder.com/300x200?text=Featured+Product" class="card-img-top" alt="Sản phẩm nổi bật">
                <div class="card-body">
                    <h5 class="card-title">Áo khoác Denim Vintage</h5>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-primary fw-bold">$45.00</span>
                        <span class="badge bg-primary">Tốt</span>
                    </div>
                    <div class="mt-2">
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star text-warning"></i>
                        <i class="bi bi-star text-warning"></i>
                        <small class="text-muted ms-1">(9)</small>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-grid">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="3" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <img src="https://via.placeholder.com/300x200?text=Featured+Product" class="card-img-top" alt="Sản phẩm nổi bật">
                <div class="card-body">
                    <h5 class="card-title">Bàn làm việc gỗ</h5>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-primary fw-bold">$120.00</span>
                        <span class="badge bg-success">Như mới</span>
                    </div>
                    <div class="mt-2">
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <small class="text-muted ms-1">(32)</small>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-grid">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="4" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Giới thiệu về nền tảng -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h2>Về EcommerceSecondHand</h2>
                            <p class="lead">Nền tảng mua bán hàng đã qua sử dụng uy tín và chất lượng.</p>
                            <p>Chúng tôi kết nối người mua và người bán với nhau để tạo ra một cộng đồng trao đổi hàng hóa đã qua sử dụng. Mua sắm trên EcommerceSecondHand không chỉ giúp bạn tiết kiệm chi phí mà còn góp phần bảo vệ môi trường.</p>
                            <div class="row mt-4">
                                <div class="col-md-4 text-center mb-3">
                                    <i class="bi bi-shield-check fs-1 text-primary"></i>
                                    <h5>An toàn</h5>
                                    <p class="small">Đảm bảo giao dịch an toàn</p>
                                </div>
                                <div class="col-md-4 text-center mb-3">
                                    <i class="bi bi-cash-coin fs-1 text-primary"></i>
                                    <h5>Tiết kiệm</h5>
                                    <p class="small">Giá cả hợp lý cho mọi người</p>
                                </div>
                                <div class="col-md-4 text-center mb-3">
                                    <i class="bi bi-recycle fs-1 text-primary"></i>
                                    <h5>Bền vững</h5>
                                    <p class="small">Góp phần bảo vệ môi trường</p>
                                </div>
                            </div>
                            <a asp-controller="Home" asp-action="Privacy" class="btn btn-primary mt-3">Tìm hiểu thêm</a>
                        </div>
                        <div class="col-md-6 d-none d-md-block">
                            <img src="https://via.placeholder.com/600x400?text=About+Us" class="img-fluid rounded" alt="Về chúng tôi">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Các bước sử dụng nền tảng -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-center mb-4">Cách thức hoạt động</h2>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm text-center mb-4">
                <div class="card-body">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-person-plus fs-1"></i>
                    </div>
                    <h5 class="card-title">Đăng ký</h5>
                    <p class="card-text">Tạo tài khoản miễn phí để bắt đầu mua sắm hoặc bán hàng trên nền tảng của chúng tôi.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm text-center mb-4">
                <div class="card-body">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-search fs-1"></i>
                    </div>
                    <h5 class="card-title">Tìm kiếm</h5>
                    <p class="card-text">Dễ dàng tìm kiếm các sản phẩm đã qua sử dụng với chất lượng đảm bảo.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm text-center mb-4">
                <div class="card-body">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-cart-check fs-1"></i>
                    </div>
                    <h5 class="card-title">Mua sắm</h5>
                    <p class="card-text">Thanh toán an toàn và nhận sản phẩm tại nhà với dịch vụ giao hàng nhanh chóng.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm text-center mb-4">
                <div class="card-body">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-star fs-1"></i>
                    </div>
                    <h5 class="card-title">Đánh giá</h5>
                    <p class="card-text">Chia sẻ trải nghiệm của bạn và xây dựng cộng đồng mua bán tin cậy.</p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Đăng ký nhận thông báo -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm bg-primary text-white">
                <div class="card-body py-5">
                    <div class="row align-items-center">
                        <div class="col-md-7">
                            <h2>Đăng ký nhận thông báo</h2>
                            <p>Nhận thông tin về các sản phẩm mới và ưu đãi đặc biệt qua email của bạn.</p>
                        </div>
                        <div class="col-md-5">
                            <form class="row g-3">
                                <div class="col-md-8">
                                    <input type="email" class="form-control form-control-lg" placeholder="Email của bạn">
                                </div>
                                <div class="col-md-4">
                                    <button type="submit" class="btn btn-light btn-lg w-100">Đăng ký</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>