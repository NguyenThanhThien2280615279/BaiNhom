@model WithdrawViewModel
@{
    ViewData["Title"] = "Rút tiền từ ví";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Rút tiền từ ví</h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Wallet" asp-action="Withdraw">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">VND</span>
                                <input asp-for="Amount" class="form-control" type="number" min="50000" max="100000000" step="10000">
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <div class="form-text">Số tiền tối thiểu là 50,000 VND. Tối đa là 100,000,000 VND.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="WithdrawalMethod" class="form-label"></label>
                            <select asp-for="WithdrawalMethod" class="form-select" id="withdrawalMethod">
                                <option value="">-- Chọn phương thức rút tiền --</option>
                                <option value="BankTransfer">Chuyển khoản ngân hàng</option>
                                <option value="Momo">Ví MoMo</option>
                                <option value="ZaloPay">ZaloPay</option>
                                <option value="VNPay">VNPay</option>
                            </select>
                            <span asp-validation-for="WithdrawalMethod" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="AccountInfo" class="form-label"></label>
                            <div id="bankTransferFields" class="withdrawal-fields" style="display: none;">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="bankName" placeholder="Tên ngân hàng">
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="accountNumber" placeholder="Số tài khoản">
                                    </div>
                                    <div class="col-12">
                                        <input type="text" class="form-control mb-2" id="accountName" placeholder="Tên chủ tài khoản">
                                    </div>
                                    <div class="col-12">
                                        <input type="text" class="form-control mb-2" id="branch" placeholder="Chi nhánh (nếu có)">
                                    </div>
                                </div>
                            </div>
                            
                            <div id="ewalletFields" class="withdrawal-fields" style="display: none;">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="phoneNumber" placeholder="Số điện thoại">
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control mb-2" id="fullName" placeholder="Họ và tên">
                                    </div>
                                </div>
                            </div>
                            
                            <textarea asp-for="AccountInfo" class="form-control" rows="3" placeholder="Thông tin tài khoản" readonly style="display: none;"></textarea>
                            <span asp-validation-for="AccountInfo" class="text-danger"></span>
                            <div class="form-text">Vui lòng nhập đầy đủ thông tin tài khoản để nhận tiền.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú nếu có"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <div class="alert alert-warning">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h5 class="alert-heading">Lưu ý quan trọng</h5>
                                        <p class="mb-0">Sau khi nhấn "Rút tiền", yêu cầu của bạn sẽ được gửi đến admin để xử lý. Quá trình này có thể mất từ 1-3 ngày làm việc. Vui lòng kiểm tra kỹ thông tin tài khoản để tránh sai sót.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/Wallet" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-wallet2"></i> Rút tiền
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Điều khoản và điều kiện</h5>
                </div>
                <div class="card-body">
                    <ol>
                        <li>Số tiền tối thiểu cho mỗi lần rút là 50,000 VND.</li>
                        <li>Số tiền tối đa cho mỗi lần rút là 100,000,000 VND.</li>
                        <li>Phí rút tiền: Miễn phí (trong thời gian khuyến mãi).</li>
                        <li>Thời gian xử lý: 1-3 ngày làm việc.</li>
                        <li>Yêu cầu rút tiền chỉ được chấp nhận khi tài khoản của bạn đã được xác minh.</li>
                        <li>Tiền sẽ chỉ được chuyển đến tài khoản có tên chính chủ trùng với tên tài khoản của bạn trên hệ thống.</li>
                        <li>Nếu thông tin tài khoản không chính xác, yêu cầu rút tiền có thể bị từ chối và bạn sẽ cần tạo yêu cầu mới.</li>
                        <li>Đối với các yêu cầu rút tiền trên 10,000,000 VND, chúng tôi có thể yêu cầu xác minh bổ sung.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Xử lý hiển thị các trường thông tin dựa trên phương thức rút tiền
            $('#withdrawalMethod').change(function() {
                const method = $(this).val();
                $('.withdrawal-fields').hide();
                $('#AccountInfo').hide().val('');
                
                if (method === 'BankTransfer') {
                    $('#bankTransferFields').show();
                    resetFields('#ewalletFields input');
                } else if (['Momo', 'ZaloPay', 'VNPay'].includes(method)) {
                    $('#ewalletFields').show();
                    resetFields('#bankTransferFields input');
                }
            });
            
            // Cập nhật thông tin tài khoản khi người dùng nhập
            $('body').on('input', '.withdrawal-fields input', function() {
                updateAccountInfo();
            });
            
            function resetFields(selector) {
                $(selector).val('');
            }
            
            function updateAccountInfo() {
                const method = $('#withdrawalMethod').val();
                let info = '';
                
                if (method === 'BankTransfer') {
                    const bankName = $('#bankName').val().trim();
                    const accountNumber = $('#accountNumber').val().trim();
                    const accountName = $('#accountName').val().trim();
                    const branch = $('#branch').val().trim();
                    
                    if (bankName || accountNumber || accountName) {
                        info = `Ngân hàng: ${bankName || 'N/A'}\n`;
                        info += `Số tài khoản: ${accountNumber || 'N/A'}\n`;
                        info += `Chủ tài khoản: ${accountName || 'N/A'}`;
                        
                        if (branch) {
                            info += `\nChi nhánh: ${branch}`;
                        }
                    }
                } else if (['Momo', 'ZaloPay', 'VNPay'].includes(method)) {
                    const phoneNumber = $('#phoneNumber').val().trim();
                    const fullName = $('#fullName').val().trim();
                    
                    if (phoneNumber || fullName) {
                        info = `${method}\n`;
                        info += `Số điện thoại: ${phoneNumber || 'N/A'}\n`;
                        info += `Họ và tên: ${fullName || 'N/A'}`;
                    }
                }
                
                if (info) {
                    $('#AccountInfo').val(info).show();
                } else {
                    $('#AccountInfo').hide().val('');
                }
            }
        });
    </script>
}