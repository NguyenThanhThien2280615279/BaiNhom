@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-4">
    <h1>Thanh toán</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Checkout" asp-action="PlaceOrder">
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label">??a ch?</label>
                            <input asp-for="ShippingAddress" class="form-control" required>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="ShippingCity" class="form-label">Thành ph?</label>
                                <input asp-for="ShippingCity" class="form-control" required>
                                <span asp-validation-for="ShippingCity" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ShippingCountry" class="form-label">Qu?c gia</label>
                                <input asp-for="ShippingCountry" class="form-control" required>
                                <span asp-validation-for="ShippingCountry" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ShippingPostalCode" class="form-label">Mã b?u ?i?n</label>
                                <input asp-for="ShippingPostalCode" class="form-control" required>
                                <span asp-validation-for="ShippingPostalCode" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <hr class="my-4">
                        
                        <h5>Ph??ng th?c thanh toán</h5>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-check card p-3 mb-2">
                                    <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="wallet" value="Wallet" checked>
                                    <label class="form-check-label w-100" for="wallet">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-wallet2 text-primary me-2" style="font-size: 1.5rem;"></i>
                                            <div>
                                                <span class="d-block">Ví ?i?n t?</span>
                                                <small class="text-muted">Thanh toán b?ng s? d? trong ví</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check card p-3 mb-2">
                                    <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="cod" value="COD">
                                    <label class="form-check-label w-100" for="cod">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-cash text-primary me-2" style="font-size: 1.5rem;"></i>
                                            <div>
                                                <span class="d-block">Thanh toán khi nh?n hàng</span>
                                                <small class="text-muted">Thanh toán b?ng ti?n m?t</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-lg">??t hàng</button>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Tóm t?t ??n hàng</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>T?m tính</span>
                        <span>@Model.Subtotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Phí v?n chuy?n</span>
                        <span>@(Model.ShippingFee > 0 ? Model.ShippingFee.ToString("C") : "Mi?n phí")</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">T?ng c?ng</span>
                        <span class="text-primary fw-bold">@Model.Total.ToString("C")</span>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">S?n ph?m (@Model.CartItems.Count())</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="list-group-item">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="img-fluid rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width: 60px; height: 60px;">
                                                <i class="bi bi-image"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0">@item.Product?.Name</h6>
                                        <div class="d-flex justify-content-between">
                                            <small class="text-muted">@item.Quantity x @item.Product?.Price.ToString("C")</small>
                                            <span>@((item.Quantity * item.Product?.Price ?? 0).ToString("C"))</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}