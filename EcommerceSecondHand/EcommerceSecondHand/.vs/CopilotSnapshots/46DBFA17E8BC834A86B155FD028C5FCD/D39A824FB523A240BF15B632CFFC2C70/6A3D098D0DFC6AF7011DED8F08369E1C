@model WithdrawViewModel
@{
    ViewData["Title"] = "Rút tiền";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Rút tiền từ ví</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Wallet" asp-action="Withdraw">
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Số tiền</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" class="form-control" placeholder="Nhập số tiền muốn rút" min="1" max="10000" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <div class="form-text">Số tiền rút tối thiểu là $1 và tối đa là $10,000</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="BankAccount" class="form-label">Thông tin tài khoản</label>
                            <textarea asp-for="BankAccount" class="form-control" rows="3" placeholder="Nhập thông tin tài khoản ngân hàng hoặc ví điện tử của bạn"></textarea>
                            <span asp-validation-for="BankAccount" class="text-danger"></span>
                            <div class="form-text">Ví dụ: Ngân hàng ABC, Số tài khoản: 123456789, Chủ tài khoản: Nguyễn Văn A</div>
                        </div>
                        
                        <div class="mb-4">
                            <h6>Phương thức rút tiền</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="withdrawMethod" id="bankTransfer" value="bankTransfer" checked>
                                <label class="form-check-label" for="bankTransfer">
                                    <i class="bi bi-bank me-2"></i> Chuyển khoản ngân hàng
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="withdrawMethod" id="paypal" value="paypal">
                                <label class="form-check-label" for="paypal">
                                    <i class="bi bi-paypal me-2"></i> PayPal
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="withdrawMethod" id="eWallet" value="eWallet">
                                <label class="form-check-label" for="eWallet">
                                    <i class="bi bi-wallet2 me-2"></i> Ví điện tử
                                </label>
                            </div>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Rút tiền</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-white">
                    <div class="text-center">
                        <a asp-controller="Wallet" asp-action="Index" class="btn btn-link">Quay lại ví của tôi</a>
                    </div>
                </div>
            </div>
            
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title">Lưu ý:</h6>
                    <ul class="mb-0">
                        <li>Yêu cầu rút tiền sẽ được xử lý trong vòng 1-3 ngày làm việc.</li>
                        <li>Phí rút tiền (nếu có) sẽ được thông báo trước khi hoàn tất giao dịch.</li>
                        <li>Số tiền sẽ được chuyển đến tài khoản bạn đã cung cấp.</li>
                        <li>Vui lòng đảm bảo thông tin tài khoản chính xác để tránh chậm trễ trong quá trình xử lý.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}