@model AdminDashboardViewModel
@{
    ViewData["Title"] = "B?ng ?i?u khi?n Admin";
}

<div class="container-fluid mt-4">
    <h1>B?ng ?i?u khi?n Admin</h1>
    
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="display-4 text-primary mb-2">@Model.TotalUsers</div>
                    <h5>T?ng ng??i dùng</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="display-4 text-success mb-2">@Model.TotalProducts</div>
                    <h5>T?ng s?n ph?m</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="display-4 text-info mb-2">@Model.TotalOrders</div>
                    <h5>T?ng ??n hàng</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="display-4 text-warning mb-2">@Model.TotalRevenue.ToString("C")</div>
                    <h5>T?ng doanh thu</h5>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">??n hàng g?n ?ây</h5>
                </div>
                <div class="card-body">
                    @if (Model.RecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Mã ??n</th>
                                        <th>Khách hàng</th>
                                        <th>Ngày ??t</th>
                                        <th>S? ti?n</th>
                                        <th>Tr?ng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td>#@order.Id</td>
                                            <td>@order.User?.FirstName @order.User?.LastName</td>
                                            <td>@order.OrderDate.ToString("g")</td>
                                            <td>@order.TotalAmount.ToString("C")</td>
                                            <td>
                                                @{
                                                    string badgeClass = order.Status switch
                                                    {
                                                        OrderStatus.Pending => "bg-warning",
                                                        OrderStatus.Processing => "bg-info",
                                                        OrderStatus.Shipped => "bg-primary",
                                                        OrderStatus.Delivered => "bg-success",
                                                        OrderStatus.Cancelled => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@order.Status.ToString()</span>
                                            </td>
                                            <td>
                                                <a asp-controller="Admin" asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Xem</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-end mt-3">
                            <a asp-controller="Admin" asp-action="Orders" class="btn btn-outline-primary">Xem t?t c? ??n hàng</a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p class="text-muted">Không tìm th?y ??n hàng nào g?n ?ây.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Th?ng kê ng??i dùng</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6>Lo?i ng??i dùng</h6>
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: @Model.CustomerPercentage%;" aria-valuenow="@Model.CustomerPercentage" aria-valuemin="0" aria-valuemax="100">
                                Khách hàng (@Model.TotalCustomers)
                            </div>
                            <div class="progress-bar bg-success" role="progressbar" style="width: @Model.VendorPercentage%;" aria-valuenow="@Model.VendorPercentage" aria-valuemin="0" aria-valuemax="100">
                                Ng??i bán (@Model.TotalVendors)
                            </div>
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @Model.AdminPercentage%;" aria-valuenow="@Model.AdminPercentage" aria-valuemin="0" aria-valuemax="100">
                                Qu?n tr? viên (@Model.TotalAdmins)
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <h6>Ng??i dùng m?i (30 ngày qua)</h6>
                        <h3 class="text-success">@Model.NewUsersLast30Days</h3>
                    </div>
                    
                    <div>
                        <h6>Ng??i dùng ho?t ??ng (30 ngày qua)</h6>
                        <h3 class="text-primary">@Model.ActiveUsersLast30Days</h3>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary w-100">Qu?n lý ng??i dùng</a>
                </div>
            </div>
            
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Thao tác nhanh</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-controller="Admin" asp-action="Categories" class="btn btn-outline-primary">Qu?n lý danh m?c</a>
                        <a asp-controller="Admin" asp-action="Products" class="btn btn-outline-primary">Qu?n lý s?n ph?m</a>
                        <a asp-controller="Admin" asp-action="Reviews" class="btn btn-outline-primary">Qu?n lý ?ánh giá</a>
                        <a asp-controller="Admin" asp-action="WalletManagement" class="btn btn-outline-primary">Qu?n lý ví</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>