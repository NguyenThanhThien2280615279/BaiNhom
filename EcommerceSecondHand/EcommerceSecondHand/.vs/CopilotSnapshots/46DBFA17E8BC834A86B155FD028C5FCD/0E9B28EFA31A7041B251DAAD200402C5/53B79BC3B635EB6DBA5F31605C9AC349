@model DepositViewModel
@{
    ViewData["Title"] = "Nạp tiền vào ví";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Nạp tiền vào ví</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Wallet" asp-action="Deposit">
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Số tiền</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" class="form-control" placeholder="Nhập số tiền muốn nạp" min="1" max="10000" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <div class="form-text">Số tiền nạp tối thiểu là $1 và tối đa là $10,000</div>
                        </div>
                        
                        <div class="mb-4">
                            <h6>Phương thức thanh toán</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard" value="creditCard" checked>
                                <label class="form-check-label" for="creditCard">
                                    <i class="bi bi-credit-card me-2"></i> Thẻ tín dụng/ghi nợ
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paypal" value="paypal">
                                <label class="form-check-label" for="paypal">
                                    <i class="bi bi-paypal me-2"></i> PayPal
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="bankTransfer" value="bankTransfer">
                                <label class="form-check-label" for="bankTransfer">
                                    <i class="bi bi-bank me-2"></i> Chuyển khoản ngân hàng
                                </label>
                            </div>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Nạp tiền</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-white">
                    <div class="text-center">
                        <a asp-controller="Wallet" asp-action="Index" class="btn btn-link">Quay lại ví của tôi</a>
                    </div>
                </div>
            </div>
            
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title">Lưu ý:</h6>
                    <ul class="mb-0">
                        <li>Tiền sẽ được cộng vào ví của bạn ngay sau khi thanh toán thành công.</li>
                        <li>Bạn có thể sử dụng số dư ví để mua sản phẩm trên hệ thống.</li>
                        <li>Mọi giao dịch nạp tiền đều được ghi lại và có thể xem trong lịch sử giao dịch.</li>
                        <li>Nếu gặp vấn đề khi nạp tiền, vui lòng liên hệ bộ phận hỗ trợ khách hàng.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}