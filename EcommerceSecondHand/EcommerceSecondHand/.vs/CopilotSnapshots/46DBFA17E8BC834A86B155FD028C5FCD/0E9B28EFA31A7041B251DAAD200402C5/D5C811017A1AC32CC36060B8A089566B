@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-4">
    <h1>Giỏ hàng của tôi</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Sản phẩm (@Model.CartItems.Count())</h5>
                    @if (Model.CartItems.Any())
                    {
                        <form method="post" asp-controller="WebCart" asp-action="ClearCart" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tất cả sản phẩm khỏi giỏ hàng?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Xóa tất cả
                            </button>
                        </form>
                    }
                </div>
                <div class="card-body">
                    @if (Model.CartItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Giá</th>
                                        <th>Số lượng</th>
                                        <th>Tổng</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.CartItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex">
                                                    @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                                    {
                                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="me-3" style="width: 80px; height: 80px; object-fit: cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 80px; height: 80px;">
                                                            <i class="bi bi-image"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <h6 class="mb-0">
                                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none">
                                                                @item.Product?.Name
                                                            </a>
                                                        </h6>
                                                        <small class="text-muted">Người bán: @item.Product?.Seller?.FirstName @item.Product?.Seller?.LastName</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@(item.Product?.Price.ToString("C") ?? "$0.00")</td>
                                            <td>
                                                <form method="post" asp-controller="WebCart" asp-action="UpdateQuantity" class="d-flex align-items-center">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="@(item.Product?.Quantity ?? 1)" class="form-control form-control-sm" style="width: 60px;" />
                                                    <button type="submit" class="btn btn-outline-primary btn-sm ms-2">
                                                        <i class="bi bi-check"></i>
                                                    </button>
                                                </form>
                                            </td>
                                            <td>@((item.Product?.Price * item.Quantity).ToString("C") ?? "$0.00")</td>
                                            <td>
                                                <form method="post" asp-controller="WebCart" asp-action="RemoveFromCart" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?');">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <p class="text-muted">Giỏ hàng của bạn đang trống.</p>
                            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">Tiếp tục mua sắm</a>
                        </div>
                    }
                </div>
            </div>
            
            <div class="d-flex justify-content-between mt-3">
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
                </a>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tổng sản phẩm:</span>
                        <span>@Model.CartItems.Count()</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tổng số lượng:</span>
                        <span>@Model.CartItems.Sum(item => item.Quantity)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <span>@Model.TotalAmount.ToString("C")</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Tổng thanh toán:</span>
                        <span class="text-primary fw-bold">@Model.TotalAmount.ToString("C")</span>
                    </div>
                    
                    <div class="d-grid">
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary @(Model.CartItems.Any() ? "" : "disabled")">
                            <i class="bi bi-credit-card me-1"></i> Thanh toán
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Phương thức thanh toán</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="wallet" checked>
                        <label class="form-check-label" for="wallet">
                            <i class="bi bi-wallet2 me-2"></i> Ví điện tử
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard">
                        <label class="form-check-label" for="creditCard">
                            <i class="bi bi-credit-card me-2"></i> Thẻ tín dụng/ghi nợ
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="cod">
                        <label class="form-check-label" for="cod">
                            <i class="bi bi-cash me-2"></i> Thanh toán khi nhận hàng
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>