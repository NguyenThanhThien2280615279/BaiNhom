@page
@model EcommerceSecondHand.Pages.Wallet.IndexModel
@using EcommerceSecondHand.Models
@{
    ViewData["Title"] = "My Wallet";
}

<div class="container mt-4">
    <h1>My Wallet</h1>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Current Balance</h5>
                    <h2 class="text-primary">@Model.CurrentBalance.ToString("C")</h2>
                    <p class="text-muted">Last updated: @DateTime.Now.ToString("g")</p>
                    
                    <div class="d-flex mt-3">
                        <a asp-page="./Deposit" class="btn btn-primary me-2">Deposit Funds</a>
                        <a asp-page="./Withdraw" class="btn btn-outline-secondary">Withdraw Funds</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quick Stats</h5>
                    <div class="row">
                        <div class="col-6">
                            <p class="text-muted mb-1">Total Deposits</p>
                            <h4>@Model.TotalDeposits.ToString("C")</h4>
                        </div>
                        <div class="col-6">
                            <p class="text-muted mb-1">Total Withdrawals</p>
                            <h4>@Model.TotalWithdrawals.ToString("C")</h4>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-6">
                            <p class="text-muted mb-1">Total Purchases</p>
                            <h4>@Model.TotalPurchases.ToString("C")</h4>
                        </div>
                        <div class="col-6">
                            <p class="text-muted mb-1">Total Sales</p>
                            <h4>@Model.TotalSales.ToString("C")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Transaction History</h5>
                </div>
                <div class="card-body">
                    @if (Model.Transactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Description</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var transaction in Model.Transactions)
                                    {
                                        <tr>
                                            <td>@transaction.CreatedAt.ToString("g")</td>
                                            <td>
                                                <span class="badge @(transaction.Type == TransactionType.Deposit || transaction.Type == TransactionType.Sale ? "bg-success" : "bg-primary")">
                                                    @transaction.Type.ToString()
                                                </span>
                                            </td>
                                            <td>@transaction.Description</td>
                                            <td class="@(transaction.Type == TransactionType.Deposit || transaction.Type == TransactionType.Sale ? "text-success" : "text-primary")">
                                                @(transaction.Type == TransactionType.Deposit || transaction.Type == TransactionType.Sale ? "+" : "-")@transaction.Amount.ToString("C")
                                            </td>
                                            <td>
                                                @{
                                                    string badgeClass = transaction.Status switch
                                                    {
                                                        TransactionStatus.Completed => "bg-success",
                                                        TransactionStatus.Pending => "bg-warning",
                                                        TransactionStatus.Failed => "bg-danger",
                                                        TransactionStatus.Cancelled => "bg-secondary",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@transaction.Status.ToString()</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p class="text-muted">No transactions found.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>