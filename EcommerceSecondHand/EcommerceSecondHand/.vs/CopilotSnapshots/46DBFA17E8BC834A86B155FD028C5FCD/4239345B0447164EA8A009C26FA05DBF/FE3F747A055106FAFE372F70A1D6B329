@page
@model EcommerceSecondHand.Pages.Notifications.IndexModel
@using EcommerceSecondHand.Models
@{
    ViewData["Title"] = "My Notifications";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>My Notifications</h1>
        <div>
            <form method="post" asp-page-handler="MarkAllAsRead">
                <button type="submit" class="btn btn-sm btn-outline-primary me-2">Mark All as Read</button>
            </form>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    @if (Model.Notifications.Any())
                    {
                        <div class="list-group">
                            @foreach (var notification in Model.Notifications)
                            {
                                <div class="list-group-item list-group-item-action @(!notification.IsRead ? "bg-light" : "")">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">
                                            @{
                                                string iconClass = notification.Type switch
                                                {
                                                    NotificationType.System => "bi-info-circle",
                                                    NotificationType.Order => "bi-box",
                                                    NotificationType.Payment => "bi-credit-card",
                                                    NotificationType.Chat => "bi-chat-dots",
                                                    NotificationType.Product => "bi-tag",
                                                    NotificationType.Review => "bi-star",
                                                    _ => "bi-bell"
                                                };
                                            }
                                            <i class="bi @iconClass me-2"></i>
                                            @notification.Title
                                        </h5>
                                        <small class="text-muted">@notification.CreatedAt.ToString("g")</small>
                                    </div>
                                    <p class="mb-2">@notification.Message</p>
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            @if (!string.IsNullOrEmpty(notification.ActionUrl))
                                            {
                                                <a href="@notification.ActionUrl" class="btn btn-sm btn-outline-primary">View Details</a>
                                            }
                                        </div>
                                        <div>
                                            @if (!notification.IsRead)
                                            {
                                                <form method="post" asp-page-handler="MarkAsRead" class="d-inline">
                                                    <input type="hidden" name="notificationId" value="@notification.Id" />
                                                    <button type="submit" class="btn btn-sm btn-link">Mark as Read</button>
                                                </form>
                                            }
                                            <form method="post" asp-page-handler="Delete" class="d-inline">
                                                <input type="hidden" name="notificationId" value="@notification.Id" />
                                                <button type="submit" class="btn btn-sm btn-link text-danger">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        @if (Model.TotalPages > 1)
                        {
                            <div class="d-flex justify-content-center mt-4">
                                <nav>
                                    <ul class="pagination">
                                        @for (int i = 1; i <= Model.TotalPages; i++)
                                        {
                                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                                <a class="page-link" href="/Notifications?page=@i">@i</a>
                                            </li>
                                        }
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <p class="text-muted">No notifications found.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>