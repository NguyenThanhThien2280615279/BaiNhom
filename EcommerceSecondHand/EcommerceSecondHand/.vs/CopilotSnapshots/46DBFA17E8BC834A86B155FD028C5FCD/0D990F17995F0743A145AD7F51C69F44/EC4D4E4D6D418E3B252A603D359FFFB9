@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-4">
    <h1>Thanh toán</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Checkout" asp-action="PlaceOrder">
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label">Địa chỉ giao hàng</label>
                            <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Nhập địa chỉ giao hàng của bạn"></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <h5 class="mb-3">Phương thức thanh toán</h5>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="wallet" value="Wallet" checked>
                                <label class="form-check-label" for="wallet">
                                    <i class="bi bi-wallet2 me-2"></i> Ví điện tử (Số dư: @Model.WalletBalance.ToString("C"))
                                </label>
                                @if (Model.WalletBalance < Model.Total)
                                {
                                    <div class="text-danger small mt-1">Số dư không đủ. <a asp-controller="Wallet" asp-action="Deposit">Nạp thêm tiền</a></div>
                                }
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="creditCard" value="CreditCard">
                                <label class="form-check-label" for="creditCard">
                                    <i class="bi bi-credit-card me-2"></i> Thẻ tín dụng/ghi nợ
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="cod" value="CashOnDelivery">
                                <label class="form-check-label" for="cod">
                                    <i class="bi bi-cash me-2"></i> Thanh toán khi nhận hàng
                                </label>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a asp-controller="WebCart" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại giỏ hàng
                            </a>
                            <button type="submit" class="btn btn-primary" @(Model.PaymentMethod == PaymentMethod.Wallet && Model.WalletBalance < Model.Total ? "disabled" : "")>
                                Đặt hàng <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Tóm tắt đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Sản phẩm (@Model.CartItems.Count())</span>
                        <span>@Model.SubTotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Phí vận chuyển</span>
                        <span>Miễn phí</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Tổng thanh toán</span>
                        <span class="text-primary fw-bold">@Model.Total.ToString("C")</span>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Sản phẩm (@Model.CartItems.Count())</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="list-group-item">
                                <div class="d-flex">
                                    @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }
                                    <div>
                                        <h6 class="mb-0">@item.Product?.Name</h6>
                                        <div class="d-flex justify-content-between">
                                            <small class="text-muted">SL: @item.Quantity</small>
                                            <span class="text-primary ms-3">
                                                @(item.Product != null ? (item.Product.Price * item.Quantity).ToString("C") : "$0.00")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('input[name="PaymentMethod"]').change(function() {
                var selectedMethod = $('input[name="PaymentMethod"]:checked').val();
                var walletBalance = @Html.Raw(Json.Serialize(Model.WalletBalance));
                var total = @Html.Raw(Json.Serialize(Model.Total));
                
                if (selectedMethod === 'Wallet' && walletBalance < total) {
                    $('.btn-primary[type="submit"]').attr('disabled', 'disabled');
                } else {
                    $('.btn-primary[type="submit"]').removeAttr('disabled');
                }
            });
        });
    </script>
}