using EcommerceSecondHand.Models;
using EcommerceSecondHand.Repositories.Interfaces;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;

namespace EcommerceSecondHand.Controllers
{
    [Authorize]
    public class WalletController : Controller
    {
        private readonly UserManager<ApplicationUser> _userManager;
        private readonly IPaymentTransactionRepository _transactionRepository;
        private readonly INotificationRepository _notificationRepository;

        public WalletController(
            UserManager<ApplicationUser> userManager,
            IPaymentTransactionRepository transactionRepository,
            INotificationRepository notificationRepository)
        {
            _userManager = userManager;
            _transactionRepository = transactionRepository;
            _notificationRepository = notificationRepository;
        }

        public async Task<IActionResult> Index(int page = 1)
        {
            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                return NotFound();
            }

            const int pageSize = 10;
            var transactions = await _transactionRepository.GetPaginatedTransactionsAsync(user.Id, page, pageSize);
            var totalCount = await _transactionRepository.GetTransactionsCountAsync(user.Id);

            var model = new WalletViewModel
            {
                WalletBalance = user.WalletBalance,
                Transactions = transactions,
                CurrentPage = page,
                TotalPages = (int)Math.Ceiling(totalCount / (double)pageSize)
            };

            return View(model);
        }

        public IActionResult Deposit()
        {
            return View(new DepositViewModel());
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Deposit(DepositViewModel model)
        {
            if (!ModelState.IsValid)
            {
                return View(model);
            }

            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                return NotFound();
            }

            // T?o mã giao d?ch
            var transactionReference = $"DEP-{Guid.NewGuid().ToString().Substring(0, 8).ToUpper()}";

            // Ghi nh?n giao d?ch
            var transaction = new PaymentTransaction
            {
                UserId = user.Id,
                Amount = model.Amount,
                Type = TransactionType.Deposit,
                Status = TransactionStatus.Completed,
                TransactionReference = transactionReference,
                Description = $"N?p ti?n vào ví - {model.PaymentMethod}",
                CreatedAt = DateTime.UtcNow,
                CompletedAt = DateTime.UtcNow
            };

            await _transactionRepository.AddAsync(transaction);
            await _transactionRepository.SaveAsync();

            // C?p nh?t s? d? ví
            user.WalletBalance += model.Amount;
            await _userManager.UpdateAsync(user);

            // T?o thông báo
            var notification = new Notification
            {
                UserId = user.Id,
                Title = "N?p ti?n thành công",
                Message = $"B?n ?ã n?p thành công {model.Amount.ToString("C")} vào ví c?a mình.",
                Type = NotificationType.Payment,
                IsRead = false,
                CreatedAt = DateTime.UtcNow,
                RelatedEntityId = transaction.Id.ToString(),
                ActionUrl = "/Wallet"
            };

            await _notificationRepository.AddAsync(notification);
            await _notificationRepository.SaveAsync();

            TempData["SuccessMessage"] = $"N?p ti?n thành công! {model.Amount.ToString("C")} ?ã ???c thêm vào ví c?a b?n.";
            return RedirectToAction(nameof(Index));
        }

        public IActionResult Withdraw()
        {
            return View(new WithdrawViewModel());
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Withdraw(WithdrawViewModel model)
        {
            if (!ModelState.IsValid)
            {
                return View(model);
            }

            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                return NotFound();
            }

            // Ki?m tra s? d?
            if (user.WalletBalance < model.Amount)
            {
                ModelState.AddModelError("Amount", "S? d? ví không ?? ?? th?c hi?n giao d?ch này.");
                return View(model);
            }

            // T?o mã giao d?ch
            var transactionReference = $"WDR-{Guid.NewGuid().ToString().Substring(0, 8).ToUpper()}";

            // Ghi nh?n giao d?ch
            var transaction = new PaymentTransaction
            {
                UserId = user.Id,
                Amount = model.Amount,
                Type = TransactionType.Withdrawal,
                Status = TransactionStatus.Completed,
                TransactionReference = transactionReference,
                Description = $"Rút ti?n t? ví - {model.WithdrawalMethod}",
                CreatedAt = DateTime.UtcNow,
                CompletedAt = DateTime.UtcNow
            };

            await _transactionRepository.AddAsync(transaction);
            await _transactionRepository.SaveAsync();

            // C?p nh?t s? d? ví
            user.WalletBalance -= model.Amount;
            await _userManager.UpdateAsync(user);

            // T?o thông báo
            var notification = new Notification
            {
                UserId = user.Id,
                Title = "Rút ti?n thành công",
                Message = $"B?n ?ã rút thành công {model.Amount.ToString("C")} t? ví c?a mình.",
                Type = NotificationType.Payment,
                IsRead = false,
                CreatedAt = DateTime.UtcNow,
                RelatedEntityId = transaction.Id.ToString(),
                ActionUrl = "/Wallet"
            };

            await _notificationRepository.AddAsync(notification);
            await _notificationRepository.SaveAsync();

            TempData["SuccessMessage"] = $"Rút ti?n thành công! {model.Amount.ToString("C")} ?ã ???c rút t? ví c?a b?n.";
            return RedirectToAction(nameof(Index));
        }
    }
}