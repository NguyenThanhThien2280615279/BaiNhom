using System.ComponentModel.DataAnnotations;

namespace EcommerceSecondHand.Models.ViewModels
{
    public class WithdrawViewModel
    {
        [Required(ErrorMessage = "Vui lòng nhập số tiền.")]
        [Range(50000, 100000000, ErrorMessage = "Số tiền phải từ 50,000 đến 100,000,000.")]
        [Display(Name = "Số tiền")]
        public decimal Amount { get; set; }
        
        [Required(ErrorMessage = "Vui lòng chọn phương thức rút tiền.")]
        [Display(Name = "Phương thức rút tiền")]
        public string WithdrawalMethod { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "Vui lòng nhập thông tin tài khoản.")]
        [Display(Name = "Thông tin tài khoản")]
        public string AccountInfo { get; set; } = string.Empty;
        
        [Display(Name = "Ghi chú")]
        public string? Note { get; set; }
    }
}