@model DepositViewModel
@{
    ViewData["Title"] = "Nạp tiền vào ví";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Nạp tiền vào ví</h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Wallet" asp-action="Deposit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">VND</span>
                                <input asp-for="Amount" class="form-control" type="number" min="10000" max="100000000" step="10000">
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <div class="form-text">Số tiền tối thiểu là 10,000 VND. Tối đa là 100,000,000 VND.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="PaymentMethod" class="form-label"></label>
                            <select asp-for="PaymentMethod" class="form-select">
                                <option value="">-- Chọn phương thức thanh toán --</option>
                                <option value="BankTransfer">Chuyển khoản ngân hàng</option>
                                <option value="Momo">Ví MoMo</option>
                                <option value="ZaloPay">ZaloPay</option>
                                <option value="VNPay">VNPay</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú nếu có"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <div class="alert alert-info">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        <i class="bi bi-info-circle-fill"></i>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h5 class="alert-heading">Lưu ý quan trọng</h5>
                                        <p class="mb-0">Sau khi nhấn "Nạp tiền", bạn sẽ nhận được hướng dẫn để hoàn tất giao dịch. Số tiền sẽ được cộng vào ví của bạn sau khi admin xác nhận giao dịch đã hoàn tất.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/Wallet" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-wallet2"></i> Nạp tiền
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Hướng dẫn nạp tiền</h5>
                </div>
                <div class="card-body">
                    <div class="accordion" id="depositInstructions">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingBankTransfer">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBankTransfer" aria-expanded="true" aria-controls="collapseBankTransfer">
                                    Chuyển khoản ngân hàng
                                </button>
                            </h2>
                            <div id="collapseBankTransfer" class="accordion-collapse collapse show" aria-labelledby="headingBankTransfer">
                                <div class="accordion-body">
                                    <ol>
                                        <li>Chuyển khoản đến tài khoản sau:</li>
                                        <div class="card bg-light mt-2 mb-3">
                                            <div class="card-body">
                                                <p class="mb-1"><strong>Ngân hàng:</strong> Vietcombank</p>
                                                <p class="mb-1"><strong>Số tài khoản:</strong> 1234567890</p>
                                                <p class="mb-1"><strong>Chủ tài khoản:</strong> CÔNG TY TNHH ECOMMERCE SECOND HAND</p>
                                                <p class="mb-0"><strong>Nội dung:</strong> NAP [Email của bạn]</p>
                                            </div>
                                        </div>
                                        <li>Sau khi chuyển khoản, vui lòng chờ xác nhận từ admin (thường trong vòng 24 giờ làm việc).</li>
                                        <li>Tiền sẽ được cộng vào tài khoản của bạn sau khi giao dịch được xác nhận.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                        
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingMomo">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMomo" aria-expanded="false" aria-controls="collapseMomo">
                                    Ví MoMo
                                </button>
                            </h2>
                            <div id="collapseMomo" class="accordion-collapse collapse" aria-labelledby="headingMomo">
                                <div class="accordion-body">
                                    <ol>
                                        <li>Quét mã QR hoặc chuyển tiền đến số điện thoại:</li>
                                        <div class="card bg-light mt-2 mb-3">
                                            <div class="card-body text-center">
                                                <p class="mb-1"><strong>Số điện thoại:</strong> 0987654321</p>
                                                <p class="mb-1"><strong>Tên tài khoản:</strong> ECOMMERCE SECOND HAND</p>
                                                <p class="mb-0"><strong>Nội dung:</strong> NAP [Email của bạn]</p>
                                                <!-- Placeholder for QR code -->
                                                <div class="mt-3 mb-2 bg-white p-2 d-inline-block">
                                                    <img src="https://placehold.co/200x200/png?text=Momo+QR" alt="Momo QR Code" class="img-fluid">
                                                </div>
                                            </div>
                                        </div>
                                        <li>Sau khi chuyển tiền, vui lòng chờ xác nhận từ admin.</li>
                                        <li>Tiền sẽ được cộng vào tài khoản của bạn sau khi giao dịch được xác nhận.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                        
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingZaloPay">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseZaloPay" aria-expanded="false" aria-controls="collapseZaloPay">
                                    ZaloPay
                                </button>
                            </h2>
                            <div id="collapseZaloPay" class="accordion-collapse collapse" aria-labelledby="headingZaloPay">
                                <div class="accordion-body">
                                    <ol>
                                        <li>Quét mã QR hoặc chuyển tiền đến số điện thoại:</li>
                                        <div class="card bg-light mt-2 mb-3">
                                            <div class="card-body text-center">
                                                <p class="mb-1"><strong>Số điện thoại:</strong> 0987654321</p>
                                                <p class="mb-1"><strong>Tên tài khoản:</strong> ECOMMERCE SECOND HAND</p>
                                                <p class="mb-0"><strong>Nội dung:</strong> NAP [Email của bạn]</p>
                                                <!-- Placeholder for QR code -->
                                                <div class="mt-3 mb-2 bg-white p-2 d-inline-block">
                                                    <img src="https://placehold.co/200x200/png?text=ZaloPay+QR" alt="ZaloPay QR Code" class="img-fluid">
                                                </div>
                                            </div>
                                        </div>
                                        <li>Sau khi chuyển tiền, vui lòng chờ xác nhận từ admin.</li>
                                        <li>Tiền sẽ được cộng vào tài khoản của bạn sau khi giao dịch được xác nhận.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                        
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingVNPay">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseVNPay" aria-expanded="false" aria-controls="collapseVNPay">
                                    VNPay
                                </button>
                            </h2>
                            <div id="collapseVNPay" class="accordion-collapse collapse" aria-labelledby="headingVNPay">
                                <div class="accordion-body">
                                    <ol>
                                        <li>Quét mã QR hoặc nhập thông tin chuyển khoản:</li>
                                        <div class="card bg-light mt-2 mb-3">
                                            <div class="card-body text-center">
                                                <p class="mb-1"><strong>Ngân hàng:</strong> Vietcombank</p>
                                                <p class="mb-1"><strong>Số tài khoản:</strong> 1234567890</p>
                                                <p class="mb-1"><strong>Chủ tài khoản:</strong> CÔNG TY TNHH ECOMMERCE SECOND HAND</p>
                                                <p class="mb-0"><strong>Nội dung:</strong> NAP [Email của bạn]</p>
                                                <!-- Placeholder for QR code -->
                                                <div class="mt-3 mb-2 bg-white p-2 d-inline-block">
                                                    <img src="https://placehold.co/200x200/png?text=VNPay+QR" alt="VNPay QR Code" class="img-fluid">
                                                </div>
                                            </div>
                                        </div>
                                        <li>Sau khi chuyển tiền, vui lòng chờ xác nhận từ admin.</li>
                                        <li>Tiền sẽ được cộng vào tài khoản của bạn sau khi giao dịch được xác nhận.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}