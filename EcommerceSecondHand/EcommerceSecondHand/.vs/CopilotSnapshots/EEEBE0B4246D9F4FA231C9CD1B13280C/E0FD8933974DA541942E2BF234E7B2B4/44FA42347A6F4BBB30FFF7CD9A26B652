                                            (p.Description != null && p.Description.Contains(query)));
            }
            
            if (!string.IsNullOrWhiteSpace(categoryId) && int.TryParse(categoryId, out int catId))
            {
                dbQuery = dbQuery.Where(p => p.CategoryId == catId);
            }
            
            if (minPrice.HasValue)
            {
                dbQuery = dbQuery.Where(p => p.Price >= minPrice.Value);
            }
            
            if (maxPrice.HasValue)
            {
                dbQuery = dbQuery.Where(p => p.Price <= maxPrice.Value);
            }
            
            if (condition.HasValue)
