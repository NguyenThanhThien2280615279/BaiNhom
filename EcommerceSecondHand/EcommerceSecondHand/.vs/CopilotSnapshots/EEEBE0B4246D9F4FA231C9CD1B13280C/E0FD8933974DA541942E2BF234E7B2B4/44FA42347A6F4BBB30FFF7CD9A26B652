        public async Task<IEnumerable<Product>> GetProductsWithFiltersAsync(int? categoryId, decimal? minPrice, decimal? maxPrice, ProductCondition? condition)
        {
            var query = _dbSet.AsQueryable();

            if (categoryId.HasValue)
            {
                query = query.Where(p => p.CategoryId == categoryId.Value);
            }

            if (minPrice.HasValue)
            {
                query = query.Where(p => p.Price >= minPrice.Value);
            }

            if (maxPrice.HasValue)
            {
                query = query.Where(p => p.Price <= maxPrice.Value);
            }

            if (condition.HasValue)
            {
                query = query.Where(p => p.Condition == condition.Value);
            }

            return await query
                .Include(p => p.Category)
                .Include(p => p.Seller)
                .ToListAsync();
        }

        public async Task<Product?> GetProductWithDetailsAsync(int id)
        {
            return await _dbSet
                .Include(p => p.Category)
                .Include(p => p.Seller)
                .Include(p => p.Reviews)
                    .ThenInclude(r => r.User)
                .FirstOrDefaultAsync(p => p.Id == id);
        }

        public async Task<IEnumerable<Product>> GetFilteredProductsAsync(int? categoryId, string? searchQuery, string? sortOrder, int page, int pageSize)
        {
            var query = _dbSet.AsQueryable();

            // Apply filters
            if (categoryId.HasValue)
            {
                query = query.Where(p => p.CategoryId == categoryId.Value);
            }

            if (!string.IsNullOrEmpty(searchQuery))
            {
                query = query.Where(p => 
                    p.Name.Contains(searchQuery) || 
                    p.Description != null && p.Description.Contains(searchQuery));
            }

            // Apply sorting
            query = sortOrder switch
            {
                "priceAsc" => query.OrderBy(p => p.Price),
                "priceDesc" => query.OrderByDescending(p => p.Price),
                "oldest" => query.OrderBy(p => p.DateCreated),
                _ => query.OrderByDescending(p => p.DateCreated) // "newest" is default
            };

            // Apply pagination
            return await query
                .Skip((page - 1) * pageSize)
                .Take(pageSize)
                .Include(p => p.Category)
                .Include(p => p.Seller)
                .ToListAsync();
        }

