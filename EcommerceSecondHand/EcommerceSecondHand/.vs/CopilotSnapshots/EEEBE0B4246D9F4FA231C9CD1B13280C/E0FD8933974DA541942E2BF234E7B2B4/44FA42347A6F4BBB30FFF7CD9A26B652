                .Where(p => p.Name.Contains(term))
                .Select(p => p.Name)
                .Distinct()
                .Take(count)
                .ToListAsync();
        }
        
        public async Task<IEnumerable<Product>> SearchProductsAsync(
            string query,
            string categoryId,
            decimal? minPrice,
            decimal? maxPrice,
            ProductCondition? condition,
            string sortOrder,
            int page,
            int pageSize)
        {
            var dbQuery = _dbSet.AsQueryable();
            
            // Apply search filters
            if (!string.IsNullOrWhiteSpace(query))
            {
                dbQuery = dbQuery.Where(p => p.Name.Contains(query) || 
                                            (p.Description != null && p.Description.Contains(query)));
            }
            
            if (!string.IsNullOrWhiteSpace(categoryId) && int.TryParse(categoryId, out int catId))
            {
                dbQuery = dbQuery.Where(p => p.CategoryId == catId);
            }
            
            if (minPrice.HasValue)
            {
                dbQuery = dbQuery.Where(p => p.Price >= minPrice.Value);
            }
            
            if (maxPrice.HasValue)
            {
                dbQuery = dbQuery.Where(p => p.Price <= maxPrice.Value);
            }
            
            if (condition.HasValue)
            {
                dbQuery = dbQuery.Where(p => p.Condition == condition.Value);
            }
            
            // Apply sorting
            dbQuery = sortOrder switch
            {
                "priceAsc" => dbQuery.OrderBy(p => p.Price),
                "priceDesc" => dbQuery.OrderByDescending(p => p.Price),
                "nameAsc" => dbQuery.OrderBy(p => p.Name),
                "nameDesc" => dbQuery.OrderByDescending(p => p.Name),
                "oldest" => dbQuery.OrderBy(p => p.DateCreated),
                _ => dbQuery.OrderByDescending(p => p.DateCreated) // "newest" is default
            };
            
            // Apply pagination
            return await dbQuery
                .Skip((page - 1) * pageSize)
                .Take(pageSize)
                .Include(p => p.Category)
                .Include(p => p.Seller)
                .ToListAsync();
        }
        
