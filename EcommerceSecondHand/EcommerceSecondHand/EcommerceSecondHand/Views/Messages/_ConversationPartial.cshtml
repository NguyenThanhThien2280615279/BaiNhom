@model ConversationViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<input type="hidden" id="user-id" value="@Model.UserId" />
<input type="hidden" id="contact-id" value="@Model.ContactId" />

<div class="conversation">
    <div class="conversation-header">
        <div class="d-flex align-items-center p-3 border-bottom">
            <div class="flex-shrink-0">
                @if (!string.IsNullOrEmpty(Model.Contact?.ProfilePicture))
                {
                    <img src="@Model.Contact.ProfilePicture" class="rounded-circle" alt="@Model.Contact.FirstName"
                        width="40" height="40" style="object-fit: cover;">
                }
                else
                {
                    <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                }
            </div>
            <div class="flex-grow-1 ms-3">
                <h5 class="mb-0">@Model.Contact?.FirstName @Model.Contact?.LastName</h5>
                <small class="text-muted">
                    @if (Model.Contact?.LastActiveAt != null)
                    {
                        var lastActive = DateTime.UtcNow - Model.Contact.LastActiveAt.Value;
                        if (lastActive.TotalMinutes < 5)
                        {
                            <span class="text-success">
                                <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i>
                                Đang hoạt động
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">
                                <i class="bi bi-circle" style="font-size: 0.5rem;"></i>
                                Không hoạt động
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">
                            <i class="bi bi-circle" style="font-size: 0.5rem;"></i>
                            Không hoạt động
                        </span>
                    }
                </small>
            </div>
        </div>
    </div>

    <div class="conversation-body" id="messages-container" style="height: 400px; overflow-y: auto; padding: 1rem;">
        @if (Model.Messages.Any())
        {
            foreach (var message in Model.Messages)
            {
                var isMine = message.SenderId == Model.UserId;
                <div class="message @(isMine ? "message-mine" : "message-theirs")">
                    <div class="message-content">
                        <p>@message.Content</p>
                        <small class="message-time">@message.Timestamp.ToString("HH:mm")</small>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center my-5">
                <p class="text-muted">Chưa có tin nhắn nào. Hãy bắt đầu cuộc trò chuyện!</p>
            </div>
        }
    </div>

    <div class="conversation-footer p-3 border-top">
        <!-- Form gửi tin nhắn: chọn một trong hai theo IsAdminContact -->
        @if (Model.IsAdminContact)
        {
            <form method="post" asp-controller="Messages" asp-action="SendMessageToAdmin" class="d-flex">
                <input type="text" name="content" class="form-control me-2" placeholder="Nhập tin nhắn tới Admin..."
                    required>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i>
                </button>
            </form>
        }
        else
        {
            <form method="post" asp-controller="Messages" asp-action="SendMessage" class="d-flex">
                <input type="hidden" name="recipientId" value="@Model.ContactId" />
                <input type="text" name="content" class="form-control me-2" placeholder="Nhập tin nhắn..." required>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i>
                </button>
            </form>
        }
    </div>
</div>

<style>
    .message {
        margin-bottom: 15px;
        display: flex;
    }

    .message-mine {
        justify-content: flex-end;
    }

    .message-theirs {
        justify-content: flex-start;
    }

    .message-content {
        max-width: 70%;
        padding: 10px 15px;
        border-radius: 18px;
        position: relative;
    }

    .message-mine .message-content {
        background-color: var(--shp-primary);
        color: white;
        border-bottom-right-radius: 5px;
    }

    .message-theirs .message-content {
        background-color: #f1f1f1;
        border-bottom-left-radius: 5px;
    }

    .message-content p {
        margin-bottom: 5px;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .message-time {
        display: block;
        font-size: 0.7rem;
        opacity: 0.7;
        text-align: right;
    }

    .message-mine .message-time {
        color: rgba(255, 255, 255, 0.8);
    }
</style>

<script></script>