@{
    ViewData["Title"] = "Test Payment - VNPay";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shp-soft">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Test Payment Mode
                    </h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-credit-card text-primary" style="font-size: 4rem;"></i>
                    </div>

                    <h5>Thông tin giao dịch</h5>
                    <div class="mb-3">
                        <strong>Mã giao dịch:</strong> <code>@ViewBag.TransactionCode</code>
                    </div>
                    <div class="mb-3">
                        <strong>Số tiền:</strong> <span class="h5 text-success">@ViewBag.Amount.ToString("N0")₫</span>
                    </div>
                    <div class="mb-3">
                        <strong>Tổng cộng:</strong> <span
                            class="h4 text-primary">@ViewBag.TotalAmount.ToString("N0")₫</span>
                    </div>
                    <div class="mb-4">
                        <strong>Mô tả:</strong> @ViewBag.OrderInfo
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Chế độ test:</strong> VNPay chưa được cấu hình. Bạn có thể test thanh toán bằng các nút
                        bên dưới.
                    </div>

                    <div class="d-grid gap-2">
                        <form method="post" asp-action="TestPaymentResult" class="d-inline">
                            <input type="hidden" name="transactionCode" value="@ViewBag.TransactionCode" />
                            <input type="hidden" name="success" value="true" />
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-check-circle me-2"></i>
                                Thanh toán thành công
                            </button>
                        </form>

                        <form method="post" asp-action="TestPaymentResult" class="d-inline">
                            <input type="hidden" name="transactionCode" value="@ViewBag.TransactionCode" />
                            <input type="hidden" name="success" value="false" />
                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                <i class="bi bi-x-circle me-2"></i>
                                Thanh toán thất bại
                            </button>
                        </form>

                        <a asp-action="Index" class="btn btn-secondary btn-lg w-100">
                            <i class="bi bi-arrow-left me-2"></i>
                            Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
