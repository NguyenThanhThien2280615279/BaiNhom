@model NotificationsViewModel
@{
    ViewData["Title"] = "Thông báo";
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Bộ lọc</h5>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="unreadOnlySwitch" @(Model.UnreadOnly ? "checked" : "")>
                        <label class="form-check-label">Chỉ hiện chưa đọc</label>
                    </div>

                    <div class="list-group list-group-flush">
                        <a href="javascript:void(0);" onclick="filterNotifications(null, @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == null ? "active" : "")">
                            🔔 Tất cả
                            <span class="badge bg-primary float-end">@Model.UnreadCount</span>
                        </a>

                        <a href="#" onclick="filterNotifications('Information', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == NotificationType.Information ? "active" : "")">
                            ℹ️ Thông tin
                        </a>

                        <a href="#" onclick="filterNotifications('Order', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == NotificationType.Order ? "active" : "")">
                            📦 Đơn hàng
                        </a>

                        <a href="#" onclick="filterNotifications('Payment', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == NotificationType.Payment ? "active" : "")">
                            💳 Thanh toán
                        </a>

                        <a href="#" onclick="filterNotifications('Message', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == NotificationType.Message ? "active" : "")">
                            💬 Tin nhắn
                        </a>

                        <a href="#" onclick="filterNotifications('Promotion', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 mb-2 @(Model.SelectedType == NotificationType.Promotion ? "active" : "")">
                            🏷️ Khuyến mãi
                        </a>

                        <a href="#" onclick="filterNotifications('Review', @(Model.UnreadOnly.ToString().ToLower()))"
                           class="list-group-item list-group-item-action rounded-3 @(Model.SelectedType == NotificationType.Review ? "active" : "")">
                            ⭐ Đánh giá
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main content -->
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold">
                            @(Model.SelectedType != null ? Model.SelectedType.ToString() : "Tất cả thông báo")
                        </h5>

                        <div>
                            <form method="post" asp-action="MarkAllAsRead" class="d-inline">
                                <button class="btn btn-sm btn-primary">✔ Đã đọc hết</button>
                            </form>

                            <form method="post" asp-action="DeleteAll" class="d-inline" onsubmit="return confirm('Xóa tất cả?');">
                                <button class="btn btn-sm btn-danger">🗑 Xóa</button>
                            </form>
                        </div>
                    </div>

                    <!-- Notifications -->
                    @if (Model.Notifications.Any())
                    {
                        foreach (var n in Model.Notifications)
                        {
                            <div class="border rounded-4 p-3 mb-3 shadow-sm @(n.IsRead ? "" : "bg-light")">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <strong>@n.Title</strong>
                                        @if (!n.IsRead)
                                        {
                                            <span class="badge bg-primary ms-2">Mới</span>
                                        }
                                    </div>
                                    <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>

                                <p class="mb-2 text-muted">@n.Message</p>

                                <div class="d-flex justify-content-between">
                                    <div>
                                        @if (!string.IsNullOrEmpty(n.ActionUrl))
                                        {
                                            <a href="@n.ActionUrl" class="btn btn-sm btn-outline-primary">Xem</a>
                                        }

                                        @if (!n.IsRead)
                                        {
                                            <form method="post" asp-action="MarkAsRead" class="d-inline">
                                                <input type="hidden" name="id" value="@n.Id" />
                                                <button class="btn btn-sm btn-outline-secondary">Đã đọc</button>
                                            </form>
                                        }
                                    </div>

                                    <form method="post" asp-action="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@n.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <h4>📭 Không có thông báo</h4>
                            <p class="text-muted">Bạn chưa có thông báo nào.</p>
                        </div>
                    }

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="#" onclick="filterNotifications('@Model.SelectedType', @(Model.UnreadOnly.ToString().ToLower()), @i)">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterNotifications(type, unreadOnly, page = 1) {
    let url = '/Notifications?';
    if (type) url += `type=${type}&`;
    if (unreadOnly) url += 'unreadOnly=true&';
    if (page > 1) url += `page=${page}`;
    window.location.href = url;
}

document.getElementById('unreadOnlySwitch').addEventListener('change', function () {
    filterNotifications('@Model.SelectedType', this.checked);
});
</script>
}}