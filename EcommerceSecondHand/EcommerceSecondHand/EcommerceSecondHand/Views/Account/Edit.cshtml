@model EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container py-5">
    <div class="row g-4">

        <!-- LEFT: PROFILE CARD -->
        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 text-center p-4">

                <!-- AVATAR -->
                <div class="position-relative">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="@Model.ProfilePicture"
                             class="rounded-circle border shadow"
                             id="preview-image"
                             style="width: 150px; height:150px; object-fit:cover;">
                    }
                    else
                    {
                        <div id="default-image"
                             class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto"
                             style="width:150px;height:150px;">
                            <i class="bi bi-person-fill" style="font-size: 4rem;"></i>
                        </div>

                        <img id="preview-image"
                             class="rounded-circle border d-none"
                             style="width:150px;height:150px;object-fit:cover;">
                    }
                </div>

                <!-- NAME -->
                <h5 class="mt-3 mb-1">
                    @Model.FirstName @Model.LastName
                </h5>
                <small class="text-muted">@Model.Email</small>

                <!-- UPLOAD -->
                <div class="mt-3">
                    <label asp-for="ProfilePictureFile" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-upload"></i> Đổi ảnh
                    </label>
                    <input asp-for="ProfilePictureFile"
                           type="file"
                           class="d-none"
                           accept="image/*"
                           onchange="previewImage(this)">
                    <span asp-validation-for="ProfilePictureFile" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- RIGHT: FORM -->
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Cập nhật thông tin
                    </h5>
                </div>

                <div class="card-body p-4">

                    <form method="post"
                          asp-controller="Account"
                          asp-action="Edit"
                          enctype="multipart/form-data">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger"></div>

                        <!-- PERSONAL -->
                        <h6 class="fw-bold mb-3 text-primary">Thông tin cá nhân</h6>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control" placeholder="Nhập họ..." />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control" placeholder="Nhập tên..." />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control bg-light" readonly />
                            </div>

                            <div class="col-12">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại..." />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- ADDRESS -->
                        <h6 class="fw-bold mb-3 text-primary">Địa chỉ</h6>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" placeholder="Số nhà, đường..." />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="City" class="form-label"></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Country" class="form-label"></label>
                                <input asp-for="Country" class="form-control" />
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="PostalCode" class="form-label"></label>
                                <input asp-for="PostalCode" class="form-control" />
                                <span asp-validation-for="PostalCode" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- BIO -->
                        <h6 class="fw-bold mb-3 text-primary">Giới thiệu</h6>

                        <div class="mb-3">
                            <label asp-for="Bio" class="form-label"></label>
                            <textarea asp-for="Bio"
                                      class="form-control"
                                      rows="4"
                                      maxlength="300"
                                      oninput="countChars(this)"></textarea>

                            <div class="text-end small text-muted">
                                <span id="charCount">0</span>/300 ký tự
                            </div>

                            <span asp-validation-for="Bio" class="text-danger small"></span>
                        </div>

                        <!-- ACTION -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Account"
                               asp-action="Profile"
                               class="btn btn-outline-secondary">
                                ← Hủy
                            </a>

                            <button type="submit"
                                    class="btn btn-primary"
                                    onclick="showLoading(this)">
                                <span class="btn-text">💾 Lưu thay đổi</span>
                                <span class="spinner-border spinner-border-sm d-none"></span>
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let img = document.getElementById('preview-image');
                    img.src = e.target.result;
                    img.classList.remove('d-none');

                    let def = document.getElementById('default-image');
                    if (def) def.classList.add('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function countChars(el) {
            document.getElementById("charCount").innerText = el.value.length;
        }

        function showLoading(btn) {
            btn.querySelector(".btn-text").classList.add("d-none");
            btn.querySelector(".spinner-border").classList.remove("d-none");
        }
    </script>
}