@{
    ViewData["Title"] = "Xác nhận đặt lại mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="card shp-soft">
                <div class="card-header bg-white d-flex align-items-center justify-content-between">
                    <h4 class="mb-0">Đặt lại mật khẩu thành công</h4>
                    <i class="bi bi-check-circle fs-4 text-success"></i>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    </div>

                    <h5 class="mb-3">Mật khẩu đã được đặt lại</h5>
                    <p class="text-muted mb-4">
                        Mật khẩu của bạn đã được đặt lại thành công.
                        Bây giờ bạn có thể đăng nhập với mật khẩu mới.
                    </p>

                    <div class="d-grid gap-2">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập ngay
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-house me-1"></i> Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
