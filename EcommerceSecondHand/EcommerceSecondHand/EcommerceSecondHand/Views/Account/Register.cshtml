@model EcommerceSecondHand.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card shp-soft">
                <div class="card-header bg-white d-flex align-items-center justify-content-between">
                    <div>
                        <h4 class="mb-0">Tạo tài khoản</h4>
                        <small class="text-muted">Chọn loại tài khoản phù hợp và điền thông tin bên dưới</small>
                    </div>
                    <i class="bi bi-person-plus fs-4 text-primary"></i>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Account" asp-action="Register">
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="p-3 border rounded h-100">
                                    <h6 class="fw-bold mb-2">Loại tài khoản</h6>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" asp-for="Role" value="Customer"
                                            id="Role_Customer" />
                                        <label class="form-check-label" for="Role_Customer">Khách hàng</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" asp-for="Role" value="Vendor"
                                            id="Role_Vendor" />
                                        <label class="form-check-label" for="Role_Vendor">Người bán</label>
                                    </div>
                                    <small class="text-muted d-block mt-2">Bạn có thể đổi sang vai trò người bán sau
                                        trong phần hồ sơ.</small>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="FirstName" class="form-label">Họ</label>
                                        <input asp-for="FirstName" class="form-control" />
                                        <span asp-validation-for="FirstName" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="LastName" class="form-label">Tên</label>
                                        <input asp-for="LastName" class="form-control" />
                                        <span asp-validation-for="LastName" class="text-danger"></span>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Email" class="form-label">Email</label>
                                        <input asp-for="Email" class="form-control" autocomplete="username" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                                        <input asp-for="ConfirmPassword" class="form-control"
                                            autocomplete="new-password" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check2-circle me-1"></i> Đăng ký
                            </button>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Đã có tài khoản? Đăng nhập
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
