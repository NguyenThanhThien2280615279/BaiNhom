@model IEnumerable<EcommerceSecondHand.Models.OnChainLog>
@{
    ViewData["Title"] = "Ví blockchain (demo)";
    var address = ViewBag.Address as string ?? "(none)";
    var isDemo = ViewBag.IsDemoMode as bool? ?? true;
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header d-flex justify-content-between align-items-center bg-light">
            <div>
                <h5 class="mb-0">Ví blockchain (demo)</h5>
                <small class="text-muted">
                    Địa chỉ ví:&nbsp;
                    <strong class="text-monospace">@address</strong>
                </small>
            </div>
            <div>
                @if (isDemo)
                {
                    <span class="badge bg-warning text-dark">Chế độ mô phỏng</span>
                }
                else
                {
                    <span class="badge bg-success">Live chain</span>
                }
            </div>
        </div>

        <div class="card-body">
            <p class="text-muted mb-4" style="font-size:14px;">
                Trang này hiển thị lịch sử "on-chain" được hệ thống lưu trong database.
                Khi hệ thống ở chế độ mock, mỗi lần người mua xác nhận đã nhận hàng,
                hệ thống sẽ ghi 1 sự kiện <code>OrderRecorded</code> cho người bán
                thay vì gửi giao dịch thật lên blockchain.
            </p>

            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted">
                    Chưa có giao dịch on-chain cho địa chỉ này.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="white-space:nowrap;">Thời gian</th>
                                <th style="white-space:nowrap;">Sự kiện</th>
                                <th style="white-space:nowrap;">Order</th>
                                <th style="white-space:nowrap;">TxHash</th>
                                <th style="white-space:nowrap;">Amount</th>
                                <th>Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td style="white-space:nowrap;">
                                        @log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                                    </td>
                                    <td>@log.EventType</td>
                                    <td>@log.OrderNumber</td>
                                    <td class="text-monospace" style="font-size:12px;">
                                        @log.TxHash
                                    </td>
                                    <td style="white-space:nowrap;">
                                        @(log.Amount.HasValue
                                            ? log.Amount.Value.ToString("N0") + " đ"
                                            : "-")
                                    </td>
                                    <td style="max-width:320px; font-size:14px;">
                                        @log.Details
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
