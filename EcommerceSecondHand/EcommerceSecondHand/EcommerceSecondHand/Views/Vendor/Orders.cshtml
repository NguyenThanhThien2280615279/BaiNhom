@model EcommerceSecondHand.Models.ViewModels.OrderListViewModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container-fluid mt-4">
    <div class="section-header fade-in-up">
        <div>
            <h1 class="section-title gradient-text">Đơn hàng</h1>
            <p class="section-subtitle">Danh sách đơn hàng của cửa hàng bạn</p>
        </div>
    </div>

    <div class="card shp-soft mb-4">
        <div class="card-body">
            @if (Model.Orders != null && Model.Orders.Any())
            {
                <div class="table-responsive">
                    <table class="table table-shopee align-middle">
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày đặt</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Tổng tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td>#@order.OrderNumber</td>
                                    <td>@order.User?.FirstName @order.User?.LastName</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span
                                            class="badge @(order.Status == OrderStatus.Canceled ? "bg-danger" : order.Status == OrderStatus.Accepted ? "bg-primary" : "bg-warning text-dark")">@order.Status</span>
                                    </td>
                                    <td class="text-end">@order.TotalAmount.ToString("N0") đ</td>
                                    <td class="text-end">
                                        <a href="/Vendor/Orders/Details/@order.Id"
                                            class="btn btn-sm btn-outline-primary">Xem</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation example">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Orders" asp-route-page="@(Model.CurrentPage - 1)">Trước</a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Orders" asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Orders" asp-route-page="@(Model.CurrentPage + 1)">Sau</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state text-center py-5">
                    <i class="bi bi-receipt" style="font-size: 3rem; color: #ccc;"></i>
                    <p class="mt-3 text-muted">Chưa có đơn hàng nào.</p>
                </div>
            }
        </div>
    </div>
</div>
