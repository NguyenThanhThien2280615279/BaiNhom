@model EcommerceSecondHand.Models.ViewModels.EditProductViewModel

<div class="container mt-4">
    <div class="section-header fade-in-up">
        <div>
            <h1 class="section-title gradient-text">Sửa sản phẩm</h1>
            <p class="section-subtitle">Cập nhật thông tin sản phẩm</p>
        </div>
    </div>

    <div class="card shp-soft">
        <div class="card-body">
            <form asp-action="EditProduct" asp-controller="Vendor" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-lg-8">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label"></label>
                                <input asp-for="Price" class="form-control" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Quantity" class="form-label"></label>
                                <input asp-for="Quantity" type="number" min="0" step="1" class="form-control" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- ✅ Công tắc điều khiển Quantity -->
                        <div class="mb-3">
                            <label class="form-label d-block">Trạng thái</label>

                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="stockSwitch">
                                <label class="form-check-label" id="stockLabel" for="stockSwitch">Còn hàng</label>
                            </div>

                            <small class="text-muted" id="stockHint"></small>
                        </div>


                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label"></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories"></select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Condition" class="form-label"></label>
                            <select asp-for="Condition" class="form-select"
                                    asp-items="Html.GetEnumSelectList<EcommerceSecondHand.Models.ProductCondition>()"></select>
                            <span asp-validation-for="Condition" class="text-danger"></span>
                        </div>

                        <!-- Hình ảnh -->
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh hiện tại</label>
                            <div>
                                <img src="@(!string.IsNullOrEmpty(Model.CurrentImageUrl) ? Model.CurrentImageUrl : "/img/placeholder.png")"
                                     class="img-thumbnail" style="width:160px;height:160px;object-fit:cover" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label"></label>
                            <input asp-for="ImageFile" type="file" class="form-control" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="col-lg-4">
                        <div class="card shp-soft h-100">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <div><h5 class="mb-3">Hành động</h5></div>
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save"></i> Lưu thay đổi
                                    </button>
                                    <a asp-action="Products" class="btn btn-outline-secondary">Quay lại</a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const qtyInput = document.querySelector('input[name="Quantity"]');
            const switchEl = document.getElementById('stockSwitch');
            const labelEl = document.getElementById('stockLabel');
            const hintEl = document.getElementById('stockHint');

            let lastPositiveQty = Math.max(1, parseInt(qtyInput.value || "1", 10) || 1);

            function refreshUI() {
                const q = parseInt(qtyInput.value || "0", 10) || 0;
                const inStock = q > 0;

                switchEl.checked = inStock;
                qtyInput.disabled = !inStock;

                labelEl.textContent = inStock ? 'Còn hàng' : 'Hết hàng';
                hintEl.textContent = inStock ? 'Khách có thể mua' : 'Sản phẩm bị ẩn khỏi mua (Số lượng = 0)';
            }

            refreshUI();

            qtyInput.addEventListener('input', () => {
                const q = parseInt(qtyInput.value || "0", 10) || 0;
                if (q > 0) lastPositiveQty = q;
                refreshUI();
            });

            switchEl.addEventListener('change', () => {
                if (switchEl.checked) {
                    if ((parseInt(qtyInput.value || "0", 10) || 0) === 0) {
                        qtyInput.value = Math.max(1, lastPositiveQty);
                    }
                } else {
                    const q = parseInt(qtyInput.value || "0", 10) || 0;
                    if (q > 0) lastPositiveQty = q;
                    qtyInput.value = 0;
                }
                refreshUI();
            });
        });
    </script>
}
