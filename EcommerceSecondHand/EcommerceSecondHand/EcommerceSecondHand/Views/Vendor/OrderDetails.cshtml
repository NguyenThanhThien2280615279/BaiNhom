@model EcommerceSecondHand.Models.Order
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model?.OrderNumber}";
}

<div class="container mt-4">
    <div class="card shp-soft mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Chi tiết đơn hàng #@Model.OrderNumber</h5>
            <span
                class="badge @(Model.Status == OrderStatus.Canceled ? "bg-danger" : Model.Status == OrderStatus.Accepted ? "bg-primary" : "bg-warning text-dark")">@Model.Status</span>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <h6 class="text-muted">Khách hàng</h6>
                    <p class="mb-1">@Model.User?.FirstName @Model.User?.LastName</p>
                    <p class="mb-1">Email: @Model.User?.Email</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted">Thông tin đơn</h6>
                    <p class="mb-1">Ngày tạo: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    @if (Model.DeliveredAt.HasValue)
                    {
                        <p class="mb-1">Ngày giao: @Model.DeliveredAt?.ToString("dd/MM/yyyy HH:mm")</p>
                    }
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-shopee align-middle">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Danh mục</th>
                            <th class="text-end">Giá</th>
                            <th class="text-end">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in (Model.OrderItems ??
                                                Enumerable.Empty<EcommerceSecondHand.Models.OrderItem>()))
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td>@item.Product?.Category?.Name</td>
                                <td class="text-end">@item.Price.ToString("N0") đ</td>
                                <td class="text-end">@item.Quantity</td>
                                <td class="text-end">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="4" class="text-end">Tổng tiền</th>
                            <th class="text-end">@Model.TotalAmount.ToString("N0") đ</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-3">
                <a asp-action="Orders" class="btn btn-outline-secondary">Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>
