@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - EcommerceSecondHand</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>

<body>
    <nav class="navbar navbar-expand-lg admin-topbar">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Admin" asp-action="Index">Admin</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin"
                            asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Categories"
                            asp-action="Index">Danh mục</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Products"
                            asp-action="Index">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Orders"
                            asp-action="Index">Đơn hàng</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Users"
                            asp-action="Index">Tài khoản</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Reviews"
                            asp-action="Index">Đánh giá</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Admin"
                            asp-action="WalletManagement">Quản lý ví</a></li>
                </ul>
                <ul class="navbar-nav">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <form class="d-inline" asp-area="Admin" asp-controller="Account" asp-action="Logout"
                                method="post">
                                <button type="submit" class="nav-link border-0 bg-transparent text-white p-0">Đăng
                                    xuất</button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <aside class="col-12 col-md-3 col-lg-2 admin-sidebar py-3 px-0">
                <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")"
                        asp-area="Admin" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Tổng quan
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")"
                        asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-tags me-2"></i>Danh mục
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")"
                        asp-area="Admin" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-box-seam me-2"></i>Sản phẩm
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")"
                        asp-area="Admin" asp-controller="Orders" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Đơn hàng
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")"
                        asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Tài khoản
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reviews" ? "active" : "")"
                        asp-area="Admin" asp-controller="Reviews" asp-action="Index">
                        <i class="bi bi-star me-2"></i>Đánh giá
                    </a>
                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "WalletManagement" ? "active" : "")"
                        asp-area="Admin" asp-controller="Admin" asp-action="WalletManagement">
                        <i class="bi bi-wallet me-2"></i>Quản lý ví
                    </a>

                    <a class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Messages" ? "active" : "")"
                        asp-area="Admin" asp-controller="Messages" asp-action="Index">
                        <i class="bi bi-chat-dots me-2"></i>Trò chuyện
                    </a>

                </div>
            </aside>
            <main role="main" class="col-12 col-md-9 col-lg-10 p-4">
                <div class="container-fluid">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
