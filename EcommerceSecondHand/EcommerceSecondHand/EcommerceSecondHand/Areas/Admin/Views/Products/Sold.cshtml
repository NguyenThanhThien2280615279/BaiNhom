@model IEnumerable<Product>
@{
    ViewData["Title"] = "Sản phẩm đã giao dịch";
}

<h2 class="mb-3">Sản phẩm đã giao dịch</h2>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link" asp-action="Index">Tất cả</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active" aria-current="page" asp-action="Sold">Đã giao dịch</a>
    </li>
</ul>

<div class="card shp-soft admin-table">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên</th>
                <th>Giá</th>
                <th>Danh mục</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Price.ToString("N0") đ</td>
                    <td>@p.Category?.Name</td>
                    <td><span class="badge text-bg-secondary">Đã bán/Hết hàng</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : null)">
                <a class="page-link" href="?page=@(page - 1)">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">Trang @(page) / @(totalPages)</span></li>
            <li class="page-item @(page >= totalPages ? "disabled" : null)">
                <a class="page-link" href="?page=@(page + 1)">Sau</a>
            </li>
        </ul>
    </nav>
}
