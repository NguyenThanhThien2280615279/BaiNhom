@model Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2 class="mb-3">@Model.Name</h2>

<div class="row g-3">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Giá</dt>
            <dd class="col-sm-8">@Model.Price.ToString("N0") đ</dd>
            <dt class="col-sm-4">Số lượng</dt>
            <dd class="col-sm-8">@Model.Quantity</dd>
            <dt class="col-sm-4">Tình trạng</dt>
            <dd class="col-sm-8">@Model.Condition</dd>
            <dt class="col-sm-4">Kích hoạt</dt>
            <dd class="col-sm-8">
                @if (Model.IsActive)
                {
                    <span class="badge text-bg-success">Active</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">Inactive</span>
                }
            </dd>
        </dl>
    </div>
    <div class="col-md-6">
        <p>@Model.Description</p>
    </div>
</div>

<form asp-action="ToggleActive" method="post" class="mt-3">
    <input type="hidden" name="id" value="@Model.Id" />
    @if (Model.IsActive)
    {
        <button class="btn btn-warning" type="submit">Vô hiệu hoá</button>
    }
    else
    {
        <button class="btn btn-success" type="submit">Kích hoạt</button>
    }
    <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
</form>
