@model IEnumerable<Category>
@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Danh mục</h2>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex align-items-center gap-2">
            <input class="form-control" type="text" name="search" value="@ViewBag.Search"
                placeholder="Tìm theo tên/mô tả..." style="min-width: 450px;" />
            <select class="form-select" name="pageSize" onchange="this.form.submit()" style="min-width: 120px;">
                @{
                    int ps = ViewBag.PageSize ?? 10;
                }
                <option value="10" selected="@(ps == 10)">10 / trang</option>
                <option value="20" selected="@(ps == 20)">20 / trang</option>
                <option value="50" selected="@(ps == 50)">50 / trang</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button class="btn btn-outline-primary" type="submit">Tìm</button>
        </form>
        <a class="btn btn-primary" asp-action="Create">Thêm danh mục</a>
    </div>

</div>

<div class="card shp-soft admin-table">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên</th>
                    <th>Mô tả</th>
                    <th>Số sản phẩm</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td>@c.Description</td>
                        <td>@(c.Products?.Count ?? 0)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.Id">Sửa</a>
                            <a class="btn btn-sm btn-outline-danger ms-1" asp-action="Delete" asp-route-id="@c.Id">Xoá</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    var search = (string)(ViewBag.Search ?? string.Empty);
    int pageSize = ViewBag.PageSize ?? 10;
}

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : null)">
                <a class="page-link" href="?page=@(page - 1)&search=@search&pageSize=@pageSize">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">Trang @(page) / @(totalPages)</span></li>
            <li class="page-item @(page >= totalPages ? "disabled" : null)">
                <a class="page-link" href="?page=@(page + 1)&search=@search&pageSize=@pageSize">Sau</a>
            </li>
        </ul>
    </nav>
}
