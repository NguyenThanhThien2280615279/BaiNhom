@model Category
@{
    ViewData["Title"] = "Xoá danh mục";
}

<h2>Xoá danh mục</h2>

<div class="card shp-soft mt-3" style="max-width: 720px;">
    <div class="card-body">
        <div class="alert alert-warning">Bạn có chắc muốn xoá danh mục này?</div>

        <dl class="row">
            <dt class="col-sm-2">Tên</dt>
            <dd class="col-sm-10">@Model.Name</dd>
            <dt class="col-sm-2">Mô tả</dt>
            <dd class="col-sm-10">@Model.Description</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary me-2">Huỷ</a>
                <button type="submit" class="btn btn-danger">Xoá</button>
            </div>
        </form>
    </div>
</div>
