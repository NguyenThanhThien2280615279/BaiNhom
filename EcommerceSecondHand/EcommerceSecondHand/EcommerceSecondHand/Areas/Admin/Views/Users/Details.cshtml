@model AdminUserDetailsViewModel
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-person me-2"></i>Chi tiết người dùng</h2>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.User.Id">
            <i class="bi bi-pencil me-1"></i>Chỉnh sửa
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Thông tin cơ bản -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Thông tin cá nhân</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center"
                        style="width: 80px; height: 80px;">
                        <span class="text-white fs-2 fw-bold">@Model.User.Email.Substring(0, 1).ToUpper()</span>
                    </div>
                </div>

                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold">Họ tên:</td>
                        <td>@(Model.User.FirstName + " " + Model.User.LastName)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Email:</td>
                        <td>@Model.User.Email</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Số điện thoại:</td>
                        <td>@(Model.User.PhoneNumber ?? "Chưa cập nhật")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Địa chỉ:</td>
                        <td>@(Model.User.Address ?? "Chưa cập nhật")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Thành phố:</td>
                        <td>@(Model.User.City ?? "Chưa cập nhật")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Quốc gia:</td>
                        <td>@(Model.User.Country ?? "Chưa cập nhật")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Mã bưu điện:</td>
                        <td>@(Model.User.PostalCode ?? "Chưa cập nhật")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Giới thiệu:</td>
                        <td>@(Model.User.Bio ?? "Chưa cập nhật")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Thông tin tài khoản -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-shield-check me-2"></i>Thông tin tài khoản</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold">ID:</td>
                        <td><code>@Model.User.Id</code></td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Vai trò:</td>
                        <td>
                            @if (Model.Roles.Any())
                            {
                                @foreach (var role in Model.Roles)
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Chưa có vai trò</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Số dư ví:</td>
                        <td><span class="fw-bold text-success">@Model.User.WalletBalance.ToString("N0") đ</span></td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Email đã xác thực:</td>
                        <td>
                            @if (Model.User.EmailConfirmed)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã xác thực</span>
                            }
                            else
                            {
                                <span class="badge bg-warning"><i class="bi bi-exclamation-triangle me-1"></i>Chưa xác
                                    thực</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Trạng thái khóa:</td>
                        <td>
                            @if (Model.User.LockoutEnd.HasValue && Model.User.LockoutEnd.Value > DateTimeOffset.UtcNow)
                            {
                                <span class="badge bg-danger"><i class="bi bi-lock me-1"></i>Bị khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-unlock me-1"></i>Mở khóa</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Ngày tạo:</td>
                        <td>@Model.User.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Lần đăng nhập cuối:</td>
                        <td>@(Model.User.LastLoginDate?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Chưa đăng nhập")
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Thống kê hoạt động -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Thống kê hoạt động</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-center p-3 bg-light rounded">
                            <div class="fs-4 fw-bold text-primary">@Model.Orders.Count()</div>
                            <small class="text-muted">Đơn hàng</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center p-3 bg-light rounded">
                            <div class="fs-4 fw-bold text-success">@Model.Products.Count()</div>
                            <small class="text-muted">Sản phẩm</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center p-3 bg-light rounded">
                            <div class="fs-4 fw-bold text-warning">@Model.Reviews.Count()</div>
                            <small class="text-muted">Đánh giá</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center p-3 bg-light rounded">
                            <div class="fs-4 fw-bold text-info">@Model.Transactions.Count()</div>
                            <small class="text-muted">Giao dịch</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng gần đây -->
@if (Model.Orders.Any())
{
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Đơn hàng gần đây</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Mã đơn hàng</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày đặt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders.Take(5))
                            {
                                <tr>
                                    <td><code>@order.OrderNumber</code></td>
                                    <td>@order.TotalAmount.ToString("N0") đ</td>
                                    <td>
                                        @{
                                            var statusClass = order.Status switch
                                            {
                                                OrderStatus.Pending => "badge bg-warning",
                                                OrderStatus.Accepted => "badge bg-success",
                                                OrderStatus.Canceled => "badge bg-danger",
                                                OrderStatus.Refunded => "badge bg-secondary",
                                                _ => "badge bg-secondary"
                                            };
                                        }
                                        <span class="@statusClass">@order.Status</span>
                                    </td>
                                    <td>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
