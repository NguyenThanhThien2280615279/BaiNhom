@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-people me-2"></i>Quản lý người dùng</h2>
    <form method="get" class="d-flex align-items-center gap-2">
        <input class="form-control" name="search" value="@ViewBag.Search" placeholder="Tìm theo email, họ tên..."
            style="min-width: 300px;" />
        <select class="form-select" name="role" style="min-width: 150px;">
            <option value="">Tất cả vai trò</option>
            @foreach (var r in (IEnumerable<string>)ViewBag.Roles)
            {
                <option value="@r" selected="@(ViewBag.CurrentRole == r)">@r</option>
            }
        </select>
        <select class="form-select" name="pageSize" onchange="this.form.submit()" style="min-width: 120px;">
            @{
                int ps = ViewBag.PageSize ?? 20;
            }
            <option value="10" selected="@(ps == 10)">10 / trang</option>
            <option value="20" selected="@(ps == 20)">20 / trang</option>
            <option value="50" selected="@(ps == 50)">50 / trang</option>
        </select>
        <input type="hidden" name="page" value="1" />
        <button class="btn btn-outline-primary d-flex align-items-center" type="submit">
            <i class="bi bi-search me-2"></i>Tìm
        </button>
    </form>
</div>

<div class="card shp-soft admin-table">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Thông tin</th>
                    <th>Vai trò</th>
                    <th>Ví</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var usersWithRoles = ViewBag.UsersWithRoles as List<dynamic>;
                }
                @for (int i = 0; i < Model.Count(); i++)
                {
                    var user = Model.ElementAt(i);
                    var userWithRole = usersWithRoles?.FirstOrDefault(uwr => uwr.User.Id == user.Id);
                    var userRoles = userWithRole?.Roles as IList<string> ?? new List<string>();

                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                                    style="width: 40px; height: 40px;">
                                    <span class="text-white fw-bold">@user.Email.Substring(0, 1).ToUpper()</span>
                                </div>
                                <div>
                                    <div class="fw-bold">@(user.FirstName + " " + user.LastName)</div>
                                    <small class="text-muted">@user.Email</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (userRoles.Any())
                            {
                                @foreach (var userRole in userRoles)
                                {
                                    <span class="badge bg-info me-1">@userRole</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Chưa có vai trò</span>
                            }
                        </td>
                        <td>
                            <span class="fw-bold text-success">@user.WalletBalance.ToString("N0") đ</span>
                        </td>
                        <td>
                            @if (user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-lock me-1"></i>Bị khóa
                                </span>
                            }
                            else if (user.EmailConfirmed)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Chưa xác thực
                                </span>
                            }
                        </td>
                        <td>
                            <small class="text-muted">@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</small>
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@user.Id"
                                    title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@user.Id"
                                    title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleLock" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-sm btn-outline-warning" type="submit"
                                        title="@(user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow ? "Đang bị khóa - Nhấn để mở khóa" : "Đang hoạt động - Nhấn để khóa")">
                                        <i
                                            class="bi bi-@(user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow ? "lock" : "unlock")"></i>
                                    </button>
                                </form>
                                @* Nút xóa đã bị loại bỏ theo yêu cầu *@
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    var search = (string)(ViewBag.Search ?? string.Empty);
    var role = (string)(ViewBag.CurrentRole ?? string.Empty);
    int pageSize = ViewBag.PageSize ?? 20;
}

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : null)">
                <a class="page-link" href="?page=@(page - 1)&search=@search&role=@role&pageSize=@pageSize">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">Trang @(page) / @(totalPages)</span></li>
            <li class="page-item @(page >= totalPages ? "disabled" : null)">
                <a class="page-link" href="?page=@(page + 1)&search=@search&role=@role&pageSize=@pageSize">Sau</a>
            </li>
        </ul>
    </nav>
}
